<!DOCTYPE html>
<html lang="tr">
<head>
<script src="/lib/design-system/theme.js"></script>
  <link rel="stylesheet" href="/lib/design-system/tokens.css" />
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Kalbinin Haritası — Ahlak Pusulası</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    /* ── Project-specific variables (dark default) ── */
    :root {
      --accent-green: #059669;
      --accent-green-hover: #10b981;
      --accent-green-light: #6ee7b7;
      --card-bg: rgba(31,41,55,0.85);
      --card-border: rgba(75,85,99,0.6);
      --card-hover-shadow: rgba(6,78,59,0.4);
      --option-border: #4b5563;
      --option-hover-bg: rgba(55,65,81,0.5);
      --option-selected-bg: rgba(16,185,129,0.2);
      --progress-bg: rgba(55,65,81,0.5);
      --btn-disabled-bg: #4b5563;
      --btn-gray-bg: #374151;
      --btn-gray-hover: #4b5563;
      --body-bg: #111827;
      --body-gradient-1: rgba(6,78,59,0.5);
      --body-gradient-2: rgba(16,185,129,0.4);
      --body-color: #f9fafb;
      --gemini-panel-bg: rgba(17,24,39,0.5);
      --hr-color: #374151;
    }
    html.light {
      --card-bg: rgba(255,255,255,0.85);
      --card-border: rgba(200,200,215,0.6);
      --card-hover-shadow: rgba(6,78,59,0.15);
      --option-border: #c8c8d4;
      --option-hover-bg: rgba(220,230,225,0.5);
      --option-selected-bg: rgba(16,185,129,0.12);
      --progress-bg: rgba(200,200,215,0.4);
      --btn-disabled-bg: #b0b0c0;
      --btn-gray-bg: #d4d4dc;
      --btn-gray-hover: #c0c0cc;
      --body-bg: #f5f5fa;
      --body-gradient-1: rgba(6,78,59,0.12);
      --body-gradient-2: rgba(16,185,129,0.1);
      --body-color: #1a1a2e;
      --gemini-panel-bg: rgba(240,240,245,0.7);
      --hr-color: #dddde5;
    }

    body { font-family: "Inter", sans-serif; background-color: var(--body-bg);
      background-image: radial-gradient(circle at 1% 1%, var(--body-gradient-1) 0%, transparent 40%),
        radial-gradient(circle at 99% 99%, var(--body-gradient-2) 0%, transparent 35%);
      min-height: 100vh; color: var(--body-color); }
    @keyframes fadeIn { from{opacity:0;transform:translateY(12px)} to{opacity:1;transform:translateY(0)} }
    .fade-in { animation: fadeIn 0.4s ease both; }
    .card { background:var(--card-bg); backdrop-filter:blur(8px); border:1px solid var(--card-border); border-radius:0.75rem; padding:1.5rem; transition:all 0.3s ease; }
    .card.clickable:hover { transform:translateY(-4px); box-shadow:0 20px 40px var(--card-hover-shadow); cursor:pointer; }
    .btn { display:inline-flex; align-items:center; justify-content:center; background:var(--accent-green); color:white; font-weight:700; padding:0.75rem 2rem; border-radius:0.5rem; border:none; cursor:pointer; transition:all 0.2s ease; font-size:1rem; font-family:inherit; }
    .btn:hover { background:var(--accent-green-hover); transform:scale(1.05); }
    .btn:active { transform:scale(0.97); }
    .btn:disabled { background:var(--btn-disabled-bg); cursor:not-allowed; transform:none; }
    .btn-gray { background:var(--btn-gray-bg); } .btn-gray:hover { background:var(--btn-gray-hover); transform:scale(1.02); }
    .btn-indigo { background:#4f46e5; } .btn-indigo:hover { background:#6366f1; }
    .btn-blue { background:#2563eb; } .btn-blue:hover { background:#3b82f6; }
    .option-label { display:block; padding:1rem; border-radius:0.5rem; cursor:pointer; border:2px solid var(--option-border); transition:all 0.2s; margin-bottom:0.75rem; }
    .option-label:hover { border-color:var(--accent-green-hover); background:var(--option-hover-bg); }
    .option-label.selected { background:var(--option-selected-bg); border-color:var(--accent-green-hover); box-shadow:0 0 0 2px var(--accent-green-light); transform:scale(1.02); }
    .progress-wrap { background:var(--progress-bg); border-radius:9999px; height:8px; overflow:hidden; margin-bottom:1.5rem; }
    .progress-fill { height:100%; background:var(--accent-green-hover); border-radius:9999px; transition:width 0.5s ease; }
    @keyframes spin { to { transform:rotate(360deg); } }
    .spinner { width:3rem; height:3rem; border:3px solid transparent; border-bottom-color:var(--accent-green-hover); border-radius:50%; animation:spin 0.8s linear infinite; }

    /* ── Tailwind overrides for light theme ── */
    html.light .text-gray-100 { color: #1a1a2e !important; }
    html.light .text-gray-200 { color: #2a2a40 !important; }
    html.light .text-gray-300 { color: #333350 !important; }
    html.light .text-gray-400 { color: #555570 !important; }
    html.light .text-gray-500 { color: #666680 !important; }
    html.light .text-white { color: #1a1a2e !important; }
    html.light .bg-gray-900\/50,
    html.light .bg-gray-900\/70 { background-color: var(--gemini-panel-bg) !important; }
    html.light .border-gray-700 { border-color: var(--hr-color) !important; }
    html.light hr.border-gray-700 { border-color: var(--hr-color) !important; }
    html.light .btn-gray { color: #333350; }
  </style>
  <script src="/nav.js"></script>
</head>
<body>
  <main id="app" class="container mx-auto max-w-3xl p-4 sm:p-6 py-10"></main>
<script>


const TESTS = {
    kibir: {
        title: "Aynadaki Hiçlik mi, Bulutlarda Kibir mi?",
        concepts: { tefrit: "Tezellül", fazilet: "Tevazu", ifrat: "Kibir" },
        questions: [
            { soru: "Bir iş toplantısında sunum yapmanız gerekiyor. Toplantıya geç kaldığınız için, sizin sunacağınız konuyu ekipten başka biri üstünkörü anlatmış ve ilgi toplamış. Söz size geldiğinde fark ediyorsunuz ki öne süreceğiniz fikrin çoğu önden ifade edilmiş.", options: [ { text: "“Fikrimin çalındığını düşünüp ‘Ben zaten hiçbir katkı sunamam’ hissiyle iyice susar, kendimi geri çekerim.", puan: 1 }, { text: "“İçimden bozulurum ama yine de ‘Ben kimim ki?’ diye düşünerek fikrimi tam anlatmam.”", puan: 2 }, { text: "“Sakinlikle fikrimi paylaşır, eksik kalan kısımları ekler, diğer arkadaşı da takdir ederim.”", puan: 3 }, { text: "“‘Aslında bu fikri ilk ben düşünmüştüm’ diye öne çıkıp kendi payımı vurgulamaya çalışırım.”", puan: 4 }, { text: "“Hemen savunmaya geçer, yüksek sesle ‘Bu tamamen benim fikrimdi!’ diyerek kendimi yüceltirim.”", puan: 5 } ] },
            { soru: "Arkadaşlarınız bir başarınızı tebrik etmeye hazırlanırken, tesadüfen başka bir kişinin başarısı araya giriyor ve herkes ona odaklanıyor. Sizin hakkınızda ise birkaç cılız tebrik dışında kimse konuşmuyor.", options: [ { text: "“Kendimi tamamen ikinci planda görür, ‘Bu ilgiyi zaten hak etmiyordum’ diyerek üzülürüm.”", puan: 1 }, { text: "“Biraz kırılırım ama ‘Zaten başkası varken beni kim övsün?’ diyerek iyice geriye çekilirim.”", puan: 2 }, { text: "“Fazla önemsemeden başkası adına sevinir, benim payımın hatırlanmamasını dert etmem.”", puan: 3 }, { text: "“İçten içe rahatsız olup ortama ‘Benim de büyük emeğim var’ sinyalini vermeye uğraşırım.”", puan: 4 }, { text: "“Gürültülü şekilde konuşup ‘Asıl başarı benim sayemde oldu’ diyerek sahneyi kendime çekmeye çalışırım.”", puan: 5 } ] },
            { soru: "Öğretmeniniz veya patronunuz, sizi bir konuda hatalı buluyor ve bunu yapıcı bir dille size iletiyor. Siz de hatanızın farkındasınız, ama itiraf etmesi zor geliyor.", options: [ { text: "“Aşırı mahcup olur, ‘Zaten beceriksizim’ diye daha da içine kapanırım.”", puan: 1 }, { text: "“Özür dilerdim ama kendimi çok küçük hissediyorum; belki sessizce çekilirim.”", puan: 2 }, { text: "“Dikkatle dinler, teşekkür eder, gerekli düzeltmeleri yapmaya çalışırım.”", puan: 3 }, { text: "“Kendimi savunmak için ‘Aslında şartlar elvermedi’ gibi bahanelere sığınırım.”", puan: 4 }, { text: "“Eleştiri geldiği anda tepki gösterir, ‘Siz beni yanlış anlıyorsunuz, ben hata yapmam’ diye inatlaşırım.”", puan: 5 } ] },
            { soru: "Bir konferansta, ilk defa tanıştığınız birisi sizi öve öve bitiremiyor; özellikle yeteneğinizi “harikulade” diye nitelendiriyor. Bu övgü, size biraz abartılı geliyor.", options: [ { text: "“Ona inanmayıp, ‘Ben aslında çok yetersizim’ diyerek kendimi aşağılarım.”", puan: 1 }, { text: "“Memnun olurum ama hemen çekinir, ‘Abartıyorsunuz’ deyip kaçmak isterim.”", puan: 2 }, { text: "“Teşekkür ederim, konuyu sakin bir şekilde normalleştiririm; fazla büyütmem.”", puan: 3 }, { text: "“Hoşuma gider, ‘Biraz daha bahset’ diyerek övülmeyi sürdürmek isterim.”", puan: 4 }, { text: "“Kabarır, ‘Evet, ben özel bir yeteneğe sahibim’ gibi ifadelerle kendimi yüceltmeye başlarım.”", puan: 5 } ] },
            { soru: "Bir projede ekiple tartışmaya girdiniz. Aslında ekibinizin fikri daha mantıklı geliyor ama siz bunu kabul ederseniz konumunuz sarsılacak gibi hissediyorsunuz.", options: [ { text: "“‘Ben zaten yanılıyor olmalıyım, en iyisi hiç konuşmayayım’ diye tamamen susarım.”", puan: 1 }, { text: "“İçten içe haklı olduklarını anlasam da ‘Ben kimim ki’ hissiyle tartışmayı büyütmeden çekilirim.”", puan: 2 }, { text: "“Onların fikrinin mantıklı olduğunu söyleyip meseleyi uzatmadan ortak çözüme varmaya çalışırım.”", puan: 3 }, { text: "“‘Tamam, ama benim fikrim de kötü değildi’ gibi cümlelerle kendi onurumu korumaya çalışırım.”", puan: 4 }, { text: "“Kesinlikle hatamı kabul etmem, konuyu uzatır, kendi fikrimi dayatmaya çalışırım.”", puan: 5 } ] },
            { soru: "Sosyal medyada bir paylaşımınız beklenmedik şekilde popüler oldu. Övgü dolu yorumlar alıyorsunuz ve çevreniz dikkat kesilmiş durumda.", options: [ { text: "“Rahatsız olurum, ‘Ben bunu hak edecek biri değilim, keşke paylaşmasaydım’ derim.”", puan: 1 }, { text: "“Biraz sevinecek olsam da ‘Abartılıyor, bence ben bu kadar iyi değilim’ diye kendimi geri çekerim.”", puan: 2 }, { text: "“Teşekkür ederim, ölçülü tepkiler veririm; ne şişinir ne de fazladan alçaltırım kendimi.”", puan: 3 }, { text: "“Hoşuma gidiyor, daha çok beğeni almak için ekstra paylaşımlar yapma fikri cezbedici.”", puan: 4 }, { text: "“Sürekli kendimi ön plana atarak takipçi kazanmak, beğeni rekoru kırmak ister, övgüye bağımlı hâle gelirim.”", puan: 5 } ] },
            { soru: "Bir yolculukta kayboldunuz. Yanınızdaki kişi size yardım etmeyi teklif ediyor, ancak yol sormak sizin için gurur kırıcı gibi geliyor.", options: [ { text: "“‘Ben zaten hiçbir şey beceremem’ diye düşünerek, yardımı kabul etsem bile içten içe ezik hissederim.”", puan: 1 }, { text: "“İsteksizce kabul eder, ‘Kusura bakma, çok beceriksizim ben’ diyerek utanırım.”", puan: 2 }, { text: "“Rahatça ‘Teşekkür ederim, yol konusunda desteğe ihtiyacım var’ diyerek yardım talep ederim.”", puan: 3 }, { text: "“Ayıp olmasın diye kabul ederim ama ‘Ben aslında kaybolmadım’ gibi ek ifadelerle savunma yaparım.”", puan: 4 }, { text: "“Hiçbir şekilde kaybolduğumu kabul etmem, ‘Ben zaten buraya hâkimim’ deyip suçu başkalarına atarım.”", puan: 5 } ] },
            { soru: "Okulda ya da işyerinde deneyiminiz az olsa da size “yeni gelenlere rehberlik yapma” görevi verildi. Bunun, ekibe katkı sunmanız açısından önemli olduğu söyleniyor.", options: [ { text: "“‘Ben kimim ki yol göstereyim, hiçbir faydam dokunmaz’ diyerek görevi reddederim.”", puan: 1 }, { text: "“Görevi alır ama kendimi yetersiz hisseder, pek katkı sunmadan pasif dururum.”", puan: 2 }, { text: "“Bilgim neyse açıkça aktarır, elimden gelen kadar yardım ederim, abartılı iddiaya girmem.”", puan: 3 }, { text: "“Karşımdakine zaman zaman üstten bakar, ‘Ben daha iyiyim’ hissettiren tavırlar sergilerim.”", puan: 4 }, { text: "“Bu rolü, ‘Ben burada en iyisiyim’ diyerek şov aracı yapar, sürekli kendi üstünlüğümü anlatırım.”", puan: 5 } ] },
            { soru: "Aile büyüklerinden biri, sizinle ilgili haksız bir eleştiri yapıyor. Toplum içinde sizi küçük düşürdüğünü hissediyorsunuz.", options: [ { text: "“Hiçbir savunma yapmam, içimden ‘Zaten hep haksızım’ deyip sessiz kalırım.”", puan: 1 }, { text: "“Haklı olduğumu bilsem bile, ‘Büyüktür bir bildiği vardır’ diye kendimi iyice küçültürüm.”", puan: 2 }, { text: "“Saygıyı bozmadan yanlışını ifade eder, gerekirse özür dileyerek tatlıya bağlarım.”", puan: 3 }, { text: "“Tartışmayı uzatır, ‘Benim hatam yok ki!’ diyerek inatlaşmaya başlarım.”", puan: 4 }, { text: "“Açıkça büyüğe çıkışır, ‘Sen ne anlarsın!’ tarzında sertlikle kendi onurumu korumaya çalışırım.”", puan: 5 } ] },
            { soru: "Kalabalık bir etkinlikte sunum yapacaksınız. Tam sunuma başlarken teknik bir aksaklık oluşuyor ve mikrofon bozuluyor. Herkes gözünü size dikmiş.", options: [ { text: "“Telaşa kapılır, ‘Ben zaten beceremiyorum, burada rezil oldum’ diyerek sunumu yarım bırakmaya yeltenirim.”", puan: 1 }, { text: "“Kısık sesle konuşmaya devam ederim ama kendime güvenim epey sarsılır.”", puan: 2 }, { text: "“Sakin kalır, teknik destek isteyip durumu toparlamaya çalışırım, sunuma mantıklı şekilde devam ederim.”", puan: 3 }, { text: "“Mikrofon arızası için ‘Bunu önceden test etseydiniz!’ diye ekibe çıkışıp kendimi haklı göstermeye çabalarım.”", puan: 4 }, { text: "“Ortamı yönetmeye kalkar, ‘Ben profosyonelim, bu aksaklıklar beni durduramaz’ diye kendimi öne çıkarırım.”", puan: 5 } ] },
            { soru: "Bir pozisyona aday oldunuz; rakibiniz de oldukça donanımlı biri. Karar verildi ve onu seçtiler. Çevreniz “Sen de çok iyiydin” dese de sonuç değişmedi.", options: [ { text: "“Üzülür, ‘Ben zaten hiçbir zaman kazanamam’ diye kendimi tamamen küçümserim.”", puan: 1 }, { text: "“Kıskançlık duyarım ama ‘Eh, benden iyidir’ deyip sessizce geri çekilirim.”", puan: 2 }, { text: "“O kişinin liyakatine saygı duyar, daha çok çalışarak kendimi geliştiririm.”", puan: 3 }, { text: "“İçten içe sitem eder, ‘Ben de hiç fena değildim ama şansım yokmuş’ diye moral bozarım.”", puan: 4 }, { text: "“Torpil iddiaları veya dedikodular çıkararak onun itibarını sarsmaya çalışırım.”", puan: 5 } ] },
        ]
    },
    cesaret: {
        title: "Kıpırdayamayan Yürek mi, Ateşe Atlayan Cesaret mi?",
        concepts: { tefrit: "Cübn", fazilet: "Cesaret", ifrat: "Tehevvür" },
        questions: [
            { soru: "Bir doğa kampına katıldınız, ancak kamp yeri gece tehlikeli yabani hayvanların bulunduğu bir bölgede. Rehber “Mutlaka grup hâlinde kalın, tek başınıza dolaşmayın” diyor.", options: [ { text: "Olası bir tehlike korkusuyla çadırın dışına bile çıkmam, neredeyse kampın tadını hiç alamam.", puan: 1 }, { text: "Zaman zaman dışarı çıkmak istesem de korkum ağır basar, sürekli rehberin yanında kalırım.", puan: 2 }, { text: "Rehberin uyarılarını ciddiye alır, grup hâlinde hareket eder, doğayı mantıklı tedbirle keşfederim.", puan: 3 }, { text: "Sıkılıp ‘Ne olacak canım’ diyerek bazen tek başıma orman içine dalarım, riski görmezden gelirim.", puan: 4 }, { text: "Tehlikeyi bilerek ‘Heyecan arıyorum’ diye tek başıma uzak noktalara gider, sorumsuzca davranırım.", puan: 5 } ] },
            { soru: "Bir sokakta yaşlı birine sataşan gençlerle karşılaştınız. Adam yardıma muhtaç gibi görünüyor ama gençler kalabalık.", options: [ { text: "Zarar gelmesin diye hemen gözümü kapatır, olay yerinden hızla uzaklaşırım.", puan: 1 }, { text: "Biraz beklerim, belki kendi aralarında vazgeçerler diye umut eder, doğrudan müdahale etmem.", puan: 2 }, { text: "Önce durumu değerlendirir, polise veya yakın çevreye haber vererek makul biçimde müdahale ederim.", puan: 3 }, { text: "Düşünmeden sesimi yükseltir, tek başıma kalabalık gruba çıkışırım; kendimi büyük riske atarım.", puan: 4 }, { text: "Hemen kavgaya girer, ne olursa olsun diyerek gözü kara şekilde çatışmaya hazır hâle gelirim.", puan: 5 } ] },
            { soru: "Yeni bir iş fikri duydunuz. Potansiyel kazanç çok yüksek ancak iflas riski de aynı oranda büyük.", options: [ { text: "Böyle riskli şeylere asla bulaşmam, ‘Daha garantici olayım’ diye kenarda kalırım.", puan: 1 }, { text: "İçim gitse de kaybetme korkusu yüzünden ufak tefek katkı dışında projeye girmem.", puan: 2 }, { text: "İş planını inceler, risk yönetimi yapar; mantıklıysa belirli bir sermaye koyarak katılırım.", puan: 3 }, { text: "Heyecanlanır, hızlı karar veririm; yine de ufak tefek önlemler alırım ama çok düşünmem.", puan: 4 }, { text: "‘Büyük oynayalım!’ deyip elde avuçta ne varsa yatırır, kaybetmeyi aklıma bile getirmem.", puan: 5 } ] },
            { soru: "Gece vakti karanlık bir sokağı geçmeniz gerekiyor. Taksi bulmak da zor; etrafta kimse yok. Sokağın “güvenli olmadığı” duyumlarını almışsınız.", options: [ { text: "Asla tek başıma yürümem, saatlerce bekler gerekirse hiç gitmem.", puan: 1 }, { text: "Çaresiz kalırsam adım adım yavaşça ilerler, her sesle korkup paniklerim.", puan: 2 }, { text: "Dikkatle çevreyi gözetir, hızlı ama temkinli ilerlerim; gerekiyorsa telefonumla yardım hazırlarım.", puan: 3 }, { text: "‘Korkulacak bir şey yok’ deyip yürür geçerim; tehlikeye kapıyı kısmen açarım.", puan: 4 }, { text: "‘Burası tam macera yeri’ diye düşünerek adrenalini sever, hiç tedbir almadan rahatça geçerim.", puan: 5 } ] },
            { soru: "Arkadaşlar “haftasonu dağcılık” veya “yüksekten atlama (bungee jumping)” gibi bir ekstrem spor deneyeceklerini söylüyor; sizi de davet ediyorlar.", options: [ { text: "Tehlikeli her şeyden uzak dururum; kesinlikle gitmem.", puan: 1 }, { text: "Merak etsem de ‘Başıma bir şey gelir’ korkusuyla seyirci kalırım.", puan: 2 }, { text: "Eğitmen ve güvenlik ekipmanı varsa, kurallara uyarak denemeye varım.", puan: 3 }, { text: "‘Bir an önce deneyimleyeyim’ diyerek temel eğitimleri kısmen geçiştirir, hızla atlarım.", puan: 4 }, { text: "En uç, en çılgın şekilde yapmak ister, aşırı riskleri bile göze alırım.", puan: 5 } ] },
            { soru: "İş yerinde kimsenin üstlenmek istemediği zor bir proje var. Patrondan “Gönüllü arıyorum, kimin cesareti var?” teklifi geldi.", options: [ { text: "Zorluk çok, kesin yapamam diye baştan geri çekilirim.", puan: 1 }, { text: "İstememe rağmen kendime güvenemem, ya rezil olursam diye korkarım.", puan: 2 }, { text: "Riskleri kabullenir, plan yapar, gerektiğinde yardım ister, projeyi üstlenebilirim.", puan: 3 }, { text: "Hemen ‘Ben varım’ der, detayları sonra öğrenirim; hazırlıksız yakalanabilirim.", puan: 4 }, { text: "‘Zoru ben başarırım’ diyerek gözü kapalı atlar, her şeyi tek başıma yükleneceğim diye diretirim.", puan: 5 } ] },
            { soru: "Kötü hava koşullarında otomobil kullanıyorsunuz. Kar ve buzlanma var, görüş kısıtlı. Acil yetişmeniz gereken bir toplantı da söz konusu.", options: [ { text: "Tamamen kenara çekip havanın düzelmesini bekler, ne kadar sürerse sürsün harekete geçmem.", puan: 1 }, { text: "Yola çıkarım ama aşırı korku hâkim; her an panikle durur veya çok yavaşlarım.", puan: 2 }, { text: "Hızımı ve fren mesafesini kış şartlarına göre ayarlar, dikkatli sürerim.", puan: 3 }, { text: "‘Toplantı çok önemli’ diyerek normal süratimle gider, tehlikeyi hafife alırım.", puan: 4 }, { text: "Aceleyle hızlanır, ‘Bir şey olmaz’ diyerek kayma riskini göze alırım; agresif davranırım.", puan: 5 } ] },
            { soru: "Büyük bir kalabalık önünde sunum yapmaya davet edildiniz. Hiç tecrübeniz olmasa da reddetme hakkınız var.", options: [ { text: "Elim ayağım titrer, kesinlikle yapamam deyip çekilirim.", puan: 1 }, { text: "Çıkmayı isterim ama korku baskın, muhtemelen çok zayıf bir sunum yaparım.", puan: 2 }, { text: "Heyecanı normal görür, hazırlığımı yapar, gözümü karartmadan dengeli bir şekilde çıkıp konuşurum.", puan: 3 }, { text: "Hazırlık az olsa bile bir cesaret sahneye atılırım, doğaçlama çözerim.", puan: 4 }, { text: "‘Eminim mükemmel olacağım’ diye düşünür, hiç prova yapmadan gözü kapalı çıkarım.", puan: 5 } ] },
            { soru: "Evin çatısında veya yüksek bir balkonda onarım yapmanız gerekiyor. Güvenlik ekipmanı var ama zaman alıcı.", options: [ { text: "Yükseklik korkum yüzünden asla çıkmam, gerekirse başkasına bile sormam.", puan: 1 }, { text: "Çıkmayı denerim ama panikleyip yarıda vazgeçebilirim.", puan: 2 }, { text: "Emniyet kemeri ve uygun önlemleri alarak yavaş yavaş çıkar, tamirimi yaparım.", puan: 3 }, { text: "Kemeri pek takmam, ‘Zaten dikkatliyim’ deyip hızlıca işimi görürüm.", puan: 4 }, { text: "Risk ararım, koruma tedbirlerini bile reddeder, ‘Ben alışığım’ diye gayet rahat davranırım.", puan: 5 } ] },
            { soru: "Uzun süredir çekindiğiniz birine duygularınızı açmak istiyorsunuz. Reddedilme ihtimali de var.", options: [ { text: "Katiyen konuşmam, reddedilmek korkusu her şeye engel olur.", puan: 1 }, { text: "Biraz yoklama çekerim ama tam cesaret edip itiraf edemem.", puan: 2 }, { text: "Nazikçe niyetimi söyler, sonucu olgunlukla kabullenirim.", puan: 3 }, { text: "Pat diye açılır, ince düşünmeden sonuca katlanırım.", puan: 4 }, { text: "Abartılı jestler, sürprizler yapar, reddi imkânsızmış gibi davranırım.", puan: 5 } ] },
            { soru: "Bir yurt dışı iş/öğrenim fırsatı belirdi. Aileniz “Riskli olabilir, iyi düşün” diyor. Sizse çok heveslisiniz.", options: [ { text: "Bu risk bana göre değil, hiç gitmemeyi tercih ederim.", puan: 1 }, { text: "Çok istesem de korkuya yenik düşer, vazgeçerim.", puan: 2 }, { text: "Artı-eksi hesaplar, ailemin fikrini dinler, sonra mantıklı şekilde karar veririm.", puan: 3 }, { text: "Çok düşünmeden kabul ederim, ufak tefek pürüzler umurumda olmaz.", puan: 4 }, { text: "Kim ne derse desin, anında bavulu toplar giderim; sonucu hiç hesaplamam.", puan: 5 } ] },
        ]
    },
    comertlik: {
        title: "Cebine Gömülen Hazîne mi, Kontrolsüz Altın Yağmuru mu?",
        concepts: { tefrit: "Cimrilik", fazilet: "Cömertlik", ifrat: "İsraf" },
        questions: [
            { soru: "Size önemli bir iş hediyesi veya prim geldi. Elinize toplu bir miktar para geçmiş oldu. Kişisel ihtiyaçlarınız da var, ama aynı zamanda aile/arkadaş çevrenizde yardıma ihtiyacı olanları biliyorsunuz.", options: [ { text: "Parayı bankaya koyar, hiçbir şekilde harcamaya veya paylaşmaya kıyamam; temel ihtiyaçlarımı bile ertelerim.", puan: 1 }, { text: "Çok küçük bir kısmını kullanır, geriye kalanı yığarım; çevremde yardıma muhtaç olan olsa da görmezden gelirim.", puan: 2 }, { text: "Hem kendi meşru ihtiyaçlarımı giderir hem de gücüm yettiğince paylaşır, kalanını da tasarrufa ayırırım.", puan: 3 }, { text: "Önce herkese dağıtmaya meyleder, kendi geleceğimi düşünmeden fazla açık davranırım.", puan: 4 }, { text: "Kısa sürede gösterişli harcamalar yapar, lükse dalar, ne yardımı ne birikimi aklıma getiririm.", puan: 5 } ] },
            { soru: "Aynı gün içine iki grup misafir davet ettiniz. İlk grup öğle vakti, ikinci grup akşam gelecek. Yemek ve ikram planlaması yapıyorsunuz.", options: [ { text: "Olabildiğince ucuz, minimum malzemeyle idare edeyim der, yemekleri kısıtlarım; misafir memnuniyeti aklıma gelmez.", puan: 1 }, { text: "Biraz çeşit koyarım ama çoğu zaman ‘Masraf fazla olmasın’ diye endişe eder, belki iki gruba da aynı kısıtlı menü sunarım.", puan: 2 }, { text: "Misafir sayısına göre ayarlama yapar, israf etmeden ama kimseyi de aç bırakmayacak şekilde dengeli bir sofra kurarım.", puan: 3 }, { text: "Miktarı fazla kaçırır, menüyü zenginleştirmeye çalışırken artan yemekleri nasıl saklayacağımı düşünmem.", puan: 4 }, { text: "Şov gibi bir ikram yapar, kilolarca yemek ziyan olur, kalanları atarım.", puan: 5 } ] },
            { soru: "Arkadaşlarınız hafta sonu bir eğlence etkinliği düzenliyor. Kişi başı katılım ücreti var. Sizin de aylık bütçeniz kısıtlı ama tamamen de imkânsız değil.", options: [ { text: "Eğlence harcamaya asla pay ayırmam, bunu gereksiz ve israf diye görür, bütçem olsa bile ödemem.", puan: 1 }, { text: "Zorunlu kalırsam küçük bir katkı yaparım ama içim için için rahatsızdır; keyif almak bile gözümde masraf.", puan: 2 }, { text: "Bütçeme uygun olup olmadığına bakar, müsaitsem katılır, keyif alır; maddi durum elvermiyorsa nazikçe reddederim.", puan: 3 }, { text: "Ne kadar param kalsa da eğlenceye fazla pay ayırır, temel ihtiyaçları bile sonraya ertelerim.", puan: 4 }, { text: "Mevcut param yetmezse bile borç alır, ‘Arkadaşlarla lüks eğlence’ye kaptırırım, sonunu düşünmem.", puan: 5 } ] },
            { soru: "Bir arkadaşınız ciddi bir sağlık sorunu nedeniyle borç istiyor. Ödeme gücü sınırlı olsa da, önemli bir tedavi masrafı var. Siz de maddi olarak orta hâllisiniz.", options: [ { text: "Asla para vermem, ‘Kendim ileride muhtaç kalabilirim’ korkusuyla kimseye borç vermiyorum.", puan: 1 }, { text: "Ufak bir miktar verebilirim ama gerçekten içim rahat değil, uzun vadede bile ödemesini garanti etmezse vermek istemem.", puan: 2 }, { text: "Gücüm oranında destek olur, ‘Karşılıklı güven’ anlayışıyla hem maddi hem manevi yanında olurum.", puan: 3 }, { text: "Duygusal davranır, kendim de zora düşecek ölçüde büyük borç veririm; kontrolsüzce hareket ederim.", puan: 4 }, { text: "Borcu verip vermemek umurumda değil, sadece ‘elime para geçerse yine harcarım’ gibi sorumsuzca davranırım; sonrasını hiç düşünmem.", puan: 5 } ] },
            { soru: "Markete temel alışveriş için gittiniz. İhtiyaç listesini yazdınız, ancak reyonlarda “bir alana bir bedava”, “süper indirim” gibi kampanyalar gözünüze çarpıyor.", options: [ { text: "Hatta listedeki bazı temel ürünleri bile gereksiz görüp sepete koymam, ‘Param cepte kalsın’ derim.", puan: 1 }, { text: "Bir-iki kampanya ilgimi çekse de çoğunlukla ‘Boşa para gider’ diye almam, en ucuz olanı seçerim.", puan: 2 }, { text: "Listeye sadık kalır, gerçekten ihtiyaç varsa indirimden faydalanır, gereksiz ürünleri almam.", puan: 3 }, { text: "Kampanya görünce aşırı heveslenir, biraz fazladan alsam sorun olmaz diye düşünürüm.", puan: 4 }, { text: "İndirim-değil fark etmez; canım çeken her şeyi alır, hiç hesap yapmam, sepeti doldururum.", puan: 5 } ] },
            { soru: "Bir tanıdığınız sizi misafir etti ve oldukça özenli bir sofra kurdu. Siz de iade-i ziyaretle onu ağırlamak istiyorsunuz.", options: [ { text: "En basit çay-kek ikramı dışında pek uğraşmam, ‘Gelsin otursun yeter’ diye düşünürüm.", puan: 1 }, { text: "Ufak tefek ikram yaparım ama ‘Masraf olmasın’ diye pek çeşit sunmam, içten içe cimrilik ederim.", puan: 2 }, { text: "Onu memnun edecek düzeyde hazırlık yapar, aşırıya da kaçmam; güzel ama abartısız bir ikram sunarım.", puan: 3 }, { text: "Ben de en az onun kadar iddialı bir menü hazırlamalıyım diyerek ölçüyü aşar, fazla masrafa girerim.", puan: 4 }, { text: "Şov amaçlı, lüks yemekler ve gereksiz aşırılıkla hem bütçemi sarsar hem de çok israf ederim.", puan: 5 } ] },
            { soru: "Giysi ve kişisel eşyalarınız bir hayli eskidi. Maddi durumda aşırı sıkıntınız yok ama yine de “harcama” deyince farklı tepkileriniz oluyor.", options: [ { text: "Eski de olsa kullanmaya devam ederim; paramı tutarım. Giydiğimin rengi solmuş umurumda değil.", puan: 1 }, { text: "Sadece çok ucuz ve kalitesiz şeyler alırım; çabuk yıpransa bile daha pahalıya asla yönelmem.", puan: 2 }, { text: "Gerekli eşyaları, dayanıklı ve fiyat-performans dengesi gözeterek alır, kendimi de çok sıkmam.", puan: 3 }, { text: "Alışverişe çıkınca kendimi kaptırır, bazen gereksiz markalı ürünler alır, sonra pişman olurum.", puan: 4 }, { text: "Elbise dolabım zaten dolu ama yine de canım isteyince markalar veya lüks tasarımlar alır, para harcamaktan çekinmem.", puan: 5 } ] },
            { soru: "Bir bağış kampanyası var. Uzak bir bölgede okul yaptırmak üzere yardım toplanıyor. İhtiyaç gerçek ve acil görünüyor, ama bütçeniz de kendinize göre sınırlı.", options: [ { text: "Kesinlikle katkı sağlamam, ‘Param bana lazım olabilir’ diye düşünür, adım atmam.", puan: 1 }, { text: "Çok küçük bir miktar veririm ama yine de ‘Param gitti’ diye pişman gibi hissederim.", puan: 2 }, { text: "Kendi imkânlarıma göre makul bir bağış yapar, gönül rahatlığıyla katkıda bulunurum.", puan: 3 }, { text: "Duygu yoğunluğuyla bütçemi aşan bir miktar verir, kendimi zora sokarım.", puan: 4 }, { text: "Mecbur kalır kalmaz, ‘Ne bulduysam veririm’ diye düşünür, sonra geri kalan paramı da çarçur ederim.", puan: 5 } ] },
            { soru: "Biriktirdiğiniz parayla tatile gidebilirsiniz. Uzun zamandır dinlenmeye ihtiyacınız var, fakat başka masraflarınız da kapıda.", options: [ { text: "Tatile harcamaya kıyamam, paramı orada harcamak ‘boşa gitmek’ gibi gelir.", puan: 1 }, { text: "Küçük bir gezi yapsam bile masrafı fazla görünce yarı yolda iptal edebilirim.", puan: 2 }, { text: "Bütçeme uygun şekilde, ne çok lüks ne çok özensiz, dinlendirici bir tatil seçerim.", puan: 3 }, { text: "Arkadaşların önerisiyle pahalı bir tura katılır, ‘Bir kere yaşayacağız’ diyerek sınırımı aşabilirim.", puan: 4 }, { text: "En göz alıcı ve maliyetli tatili seçer, geri dönünce borç stresiyle uğraşırım.", puan: 5 } ] },
            { soru: "Maaş veya harçlığınız elinize geçtiği gün, nasıl bir yaklaşım benimsersiniz?", options: [ { text: "Derhal kenara koyar, mümkünse hiç harcamam, adeta aç gezerim.", puan: 1 }, { text: "Biraz zorunlu harcama yapsam da kalanı ‘Karıştırmayayım’ diye bankada tutar, kendimi kısıtlarım.", puan: 2 }, { text: "İlk olarak temel masrafları karşılar, birikim ve harcama dengesini kurarım.", puan: 3 }, { text: "Keyfime göre harcama yapar, ay sonuna doğru ne yaparım pek düşünmem.", puan: 4 }, { text: "Hemen lüks tüketim veya eğlenceye yatırır, sonraki ayı borçla çeviririm.", puan: 5 } ] },
            { soru: "Ayın sonunda elinizde para kalmadı ya da çok az kaldı. Nasıl bir duygu ve düşünce içindesiniz?", options: [ { text: "Parayı hiç harcamamayı isterdim, temel ihtiyaçları bile belki fazla aldım diye pişman olurum.", puan: 1 }, { text: "Biraz birikim var ama yine de ‘Keşke daha az harcasaydım’ diye hayıflanırım.", puan: 2 }, { text: "Ay sonunu planladığım şekilde karşılar, ufak bir birikimim ya da açığım olmadan dengeli şekilde bitiririm.", puan: 3 }, { text: "Harcadıklarıma bakıp biraz fazla mı kaçtı diye dertlenirim, yine de ‘Boşver’ diyerek geçiştiririm.", puan: 4 }, { text: "Daha ilk haftadan para bitmişti zaten, kredi kartıyla, borçla idare ederim; planlı davranmam.", puan: 5 } ] },
        ]
    },
    zan: {
        title: "Zehirli Bir Şüphe mi, Çocukça Bir Saflık mı?",
        concepts: { tefrit: "Sû-i Zan", fazilet: "Hüsnü Zan", ifrat: "Aşırı Saflık" },
        questions: [
            { soru: "Yeni taşındığınız mahallede bir komşu, kapınızı çalarak size hoş geldin hediyesi getiriyor. Kendisini çok tanımıyorsunuz.", options: [ { text: "Bu kadar iyiliğin altında kesin bir art niyet var, güvenemem.", puan: 1 }, { text: "Hediye getirmesi güzel ama yine de büyük ihtimalle benden bir şey bekliyor olabilir.", puan: 2 }, { text: "Güzel bir jest olduğunu düşünür, teşekkür eder, ama yine de zamanla tanımaya çalışırım.", puan: 3 }, { text: "İnsanlar genelde masumdur, art niyeti aklıma pek getirmem; komşunun iyi niyetine hemen inanırım.", puan: 4 }, { text: "Kim olursa olsun mutlaka tertemiz kalplidir, kesinlikle benden hiçbir beklentisi olamaz.", puan: 5 } ] },
            { soru: "Arkadaşınızın sosyal medyada paylaştığı bir yardım kampanyası var. Sizden para desteği istiyor, ancak kampanyanın kaynağından emin değilsiniz.", options: [ { text: "Bu işler hep üçkâğıt, kesin dolandırıcılık. Asla destek vermem.", puan: 1 }, { text: "Belki kısmen doğru olabilir ama yine de tamamen güvensiz gelir, katılmamaya yatkınım.", puan: 2 }, { text: "Önce araştırırım, kaynağı sağlam ve mantıklıysa makul ölçüde bağış yaparım.", puan: 3 }, { text: "Arkadaşım paylaştıysa sorun yoktur; fazla sorgulamadan yardımda bulunurum.", puan: 4 }, { text: "Tüm kampanyalar mutlaka doğrudur, kimse insanları kandırmaz; sorgusuz inanır, hemen para gönderirim.", puan: 5 } ] },
            { soru: "İşyerinde yeni katılan birisi var. Arkadaşlarınız “Ona dikkat et, sinsi olabilir” diyor; ancak siz henüz bir davranışına şahit olmadınız.", options: [ { text: "Uyarmalar yeterli, kesin kötü niyetlidir, uzak durayım.", puan: 1 }, { text: "Genelde kuşkuyla bakarım, ‘Muhakkak bir iş çeviriyor olabilir’ diye temkinli yaklaşırım.", puan: 2 }, { text: "Uyarıları ciddiye alırım ama kendi gözlemimle de değerlendirmeden yargıya varmam.", puan: 3 }, { text: "İnsanların abarttığını düşünür, en baştan sıcak ve savunmasızca yaklaşırım.", puan: 4 }, { text: "Yeni gelen herkes melek gibidir; asla sinsilik yapacağını aklıma getirmem.", puan: 5 } ] },
            { soru: "Arkadaşınızın sizden sakladığını düşündüğünüz bir mevzu var. Size açıkça anlatmıyor ama kötü bir durum da göremiyorsunuz.", options: [ { text: "Bana zarar vermek için gizli kapaklı işler çeviriyordur; asla güvenmem.", puan: 1 }, { text: "Bana güvenmediğini, muhakkak olumsuz bir şey sakladığını düşünür, içten içe şüphelenirim.", puan: 2 }, { text: "Gizli bir meselesi olabilir; açıklamıyorsa vardır bir sebebi, doğrudan suçlamam.", puan: 3 }, { text: "Negatif bir durum olmadığını varsayar, konuşmak için zaman tanırım.", puan: 4 }, { text: "Arkadaşımın hiçbir şey saklamayacağına yüzde yüz eminim; asla kötü bir ihtimali düşünmem.", puan: 5 } ] },
            { soru: "Bir grup sohbetinde, tanımadığınız biri size aşırı iltifat edip “Sizi çok sevdim, gelin iş yapalım” diye ısrar ediyor.", options: [ { text: "Kesin faydalanmak istiyor; böyle davranan biri %100 tehlikeli, uzak dururum.", puan: 1 }, { text: "Büyük ihtimalle bir çıkarı var, belki çok ufak bir ihtimal iyi niyetli olabilir.", puan: 2 }, { text: "Övgü almayı hoş bulurum ama mutlaka arka planını araştırır, hemen iş yapmaya kalkmam.", puan: 3 }, { text: "Samimi olduğunu düşünür, genelde insanların boşuna iltifat etmeyeceğine inanırım.", puan: 4 }, { text: "İnsanlar beni sever, bana iltifat eden kim olsa gözü kapalı güvenir ve iş birliğine başlarım.", puan: 5 } ] },
            { soru: "Öğretmeniniz/Patronunuz, “Bu yeni ekip arkadaşı çok iyi bir yetenektir” diyerek överek tanıtıyor. Ama siz henüz pek tanışmadınız.", options: [ { text: "Patron da yanılıyor olabilir, herkes aldatıcı. Ön yargılı şekilde kuşkuyla bakarım.", puan: 1 }, { text: "Şüpheci davranır, belki gerçekten iyidir ama yine de olumlu düşünmeye zor ikna olurum.", puan: 2 }, { text: "Övgüyü duyunca mutlu olur, yine de kişisel gözlemimle tanıyıp emin olmak isterim.", puan: 3 }, { text: "Patron diyorsa doğrudur; eminim bu kişi harika bir karakterdir, pek sorgulamam.", puan: 4 }, { text: "Patronun övgüsünü duyduğum anda ‘Bu arkadaş mutlaka mükemmel, en ufak kötü tarafı olamaz’ diye düşünürüm.", puan: 5 } ] },
            { soru: "Daha önce kazık yediğiniz birisi tekrar size güzel sözlerle gelip dostluk kurmak istiyor. “Değiştim” diyor.", options: [ { text: "Bir kere aldatan hep aldatır, tekrar yaklaşırsa yine zarar verecek, asla güvenmem.", puan: 1 }, { text: "Çok büyük ihtimalle yine aynı hatayı yapar, sadece göstermelik özürdür.", puan: 2 }, { text: "Verdiği sözü, davranışını gözlemlerim; gerçekten düzelmişse yavaş yavaş yeniden güvenebilirim.", puan: 3 }, { text: "İnsanlar hata yapar ama hemen değişir; pek sorgulamadan affeder, samimiyetine inanırım.", puan: 4 }, { text: "Geçmişte ne yapmış olursa olsun, şu anda iyi niyet gösteriyorsa kesin dürüsttür, en ufak şüphe duymam.", puan: 5 } ] },
            { soru: "Bir arkadaşınız, “Başka kimseye söyleme” diyerek bir sırrını paylaştı. Sır, biraz hassas konuları içeriyor.", options: [ { text: "Bu işte bir tuzak var, bana sırrını anlatarak belki de beni suç ortağı yapmaya çalışıyor olabilir.", puan: 1 }, { text: "Arkadaşım sır veriyorsa bile arkada art niyet ararım, belki beni ileride köşeye sıkıştıracak.", puan: 2 }, { text: "Benimle paylaştığı için güvenir, kimseye anlatmadan saklarım. Arkadaşlık sorumluluğu diye düşünürüm.", puan: 3 }, { text: "Sır saklamak zor değil, zaten niyeti masumdur, üstüne pek düşünmem.", puan: 4 }, { text: "Kesinlikle safça ‘O bana güvendi, her şeyi paylaştı’ diye düşünür, en ufak kötü ihtimal gelmez aklıma.", puan: 5 } ] },
            { soru: "Mahallede biri, kapı kapı dolaşıp bağış topladığını söylüyor. Elinde birkaç kâğıt ve resim var ama resmi bir kimlik göstermedi.", options: [ { text: "Kesin dolandırıcı; mahallede böyle gezen herkesi tehlikeli görürüm.", puan: 1 }, { text: "Belki kısmen doğruluk payı var ama yine de büyük ihtimal şüpheli, vermem.", puan: 2 }, { text: "Kimliğini, belgesini sorar, güvenilir bulursam makul bir yardımda bulunurum.", puan: 3 }, { text: "İnsanların kötü niyeti olmayacağını düşünür, kimlik sormayı bile aklıma getirmem, bağış yaparım.", puan: 4 }, { text: "Kapıma gelen her yardım talebi doğrudur; asla yalan söz konusu olamaz, hemen veririm.", puan: 5 } ] },
            { soru: "Sosyal medyada tanımadığınız bir hesap, “Size özel bir proje var, çok kazandıracak!” diyerek mesaj atıyor.", options: [ { text: "Kesinlikle dolandırıcılık, bunların hepsi sahte. Hemen engellerim.", puan: 1 }, { text: "Büyük ihtimalle yalan, ama %1 ihtimal için bile tereddütlü olurum; yine de şüphede kalırım.", puan: 2 }, { text: "Kaynak ve kanıt ister, araştırırım; ikna olmazsam reddederim.", puan: 3 }, { text: "Mantıklı görünüyorsa kolayca kabul eder, fazla sorgulamadan iş birliğine heveslenirim.", puan: 4 }, { text: "İnsanlar her zaman doğruyu söyler; kesin bana çok kazandıracak iyi niyetli bir projedir!", puan: 5 } ] },
            { soru: "Bir arkadaşınız, başka bir tanıdığınız hakkında “O çok tehlikeli” dedi. Ancak siz o kişiyi normal ve saygılı tanıyorsunuz.", options: [ { text: "Arkadaşı dinler, hemen o kişiye dair kötü senaryolar üretir, ben de ondan uzak dururum.", puan: 1 }, { text: "Arkadaşım uyardığına göre haklıdır diye düşünür, yine de içimde hep bir kötü izlenim kalır.", puan: 2 }, { text: "Güvenilir kaynaktan somut kanıt yoksa peşin hüküm vermem, kendi gözlemimi yaparım.", puan: 3 }, { text: "Çoğunlukla arkadaşımın abarttığını düşünür, insanları o kadar kötü sanmam.", puan: 4 }, { text: "Biriyle ilgili asla kötü düşünmem; kim ne derse desin, insanların mutlaka iyi olduğunu varsayarım.", puan: 5 } ] },
        ]
    },
    hirs: {
        title: "Hiç Kalkmayan Miskin mi, Durmaksızın Koşan Hırs Makinesi mi?",
        concepts: { tefrit: "Tembellik", fazilet: "Çalışkanlık", ifrat: "Aşırı Hırs" },
        questions: [
            { soru: "Bitirme projesi teslimine 1 ay kaldı. Proje kapsamlı, düzenli çalışma gerektiriyor. Şu anki durumunuz?", options: [ { text: "Proje büyük diye gözüm korkar, erteleyebildiğim kadar ertelerim; belki son anda yetiştiremeyeceğim.", puan: 1 }, { text: "Başlamak isterim ama bir türlü eyleme geçemem, günleri boşa harcarım.", puan: 2 }, { text: "Zaman planı yapar, düzenli çalışır, her hafta belli aşamayı tamamlamaya özen gösteririm.", puan: 3 }, { text: "Başlarım ama bazen gereksiz ayrıntılara dalıp işkoliğe döner, sosyal hayatı unutacak kadar kendimi kaptırabilirim.", puan: 4 }, { text: "Proje her şeyim, gece gündüz demeden çalışır, sağlığımı bile riske atarım; mükemmeliyetçi yaklaşırım.", puan: 5 } ] },
            { soru: "Yeni bir kursa yazıldınız, ancak ödev ve çalışma yükü beklediğinizden fazla. İlk hafta sonu geldi.", options: [ { text: "Yorulurum, bu kadar ödev beni aşar, muhtemelen yarıda bırakırım.", puan: 1 }, { text: "Ödevleri kısmen yaparım ama çoğunu savsaklar, ‘Nasılsa not önemli değil’ diye düşünürüm.", puan: 2 }, { text: "Düzenli şekilde çalışır, ödevlerin bir kısmını planlı, bir kısmını esnek tutarak denge kurarım.", puan: 3 }, { text: "Ödevlere fazla mesai harcar, her şeyi mükemmel yapmak ister, kendimi epey zorlarım.", puan: 4 }, { text: "Her gün saatlerce sadece bu kursa odaklanır, diğer sosyal ve kişisel ihtiyaçlarımı ihmal ederim.", puan: 5 } ] },
            { soru: "Bir ek iş fırsatı çıktı, kazancı iyi ama ek mesai gerektiriyor. Mevcut işiniz veya eğitiminiz de devam ediyor.", options: [ { text: "Ek iş olsa da uğraşamam; zaten mevcut işlerime zor motive oluyorum.", puan: 1 }, { text: "Heveslensem de tembelliğim ağır basar, muhtemelen vazgeçerim.", puan: 2 }, { text: "Mevcut programımı gözden geçirir, ek işe zaman ve enerji ayırabiliyorsam kabul ederim.", puan: 3 }, { text: "Gündüz iş, akşam ek iş; kendime vakit bırakmadan yoğun bir tempoya girerim.", puan: 4 }, { text: "Günde 16 saat de çalışırım, yeter ki para kazanalım; uykuyu bile feda ederim.", puan: 5 } ] },
            { soru: "Hafta sonu tatiliniz var; gelecek hafta önemli bir sunum veya sınav bulunuyor. Nasıl davranırsınız?", options: [ { text: "Hafta sonu tamamen boş geçirir, projeye/sınava dair hiçbir şey yapmam.", puan: 1 }, { text: "Biraz bakayım derim, ama genelde TV, telefon başında oyalanır, verimli çalışmam.", puan: 2 }, { text: "Sabah veya öğleden sonra belli saatleri ayırır, hem dinlenir hem de planlı çalışırım.", puan: 3 }, { text: "Hafta sonu neredeyse tamamen çalışmaya ayırır, kendime çok az dinlenme bırakırım.", puan: 4 }, { text: "Tatil falan yok, tüm iki günü sabah akşam çalışmaya harcar, aile/arkadaş zamanını sıfırlarım.", puan: 5 } ] },
            { soru: "Bir takım çalışmasında sorumluluk paylaşımı yapılacak. Zor olan kısım size kalabilir.", options: [ { text: "Zor işi asla almam, ‘Benden beklemeyin’ diyerek geri çekilirim.", puan: 1 }, { text: "Almaya niyetlenir gibi olurum ama son anda ‘çok yorucu’ diye vazgeçerim.", puan: 2 }, { text: "Zor işse de elimden geleni yapmak için plan oluşturur, makul bir şekilde sorumluluğu kabul ederim.", puan: 3 }, { text: "Zor işleri üstlenip ekibe güvenmem, tek başıma yapmaya kalkarım, kendimi yormak pahasına.", puan: 4 }, { text: "Zorluğun beni motive ettiğini düşünür, tüm işi üstlenir ve hatta başkalarına rol bırakmam.", puan: 5 } ] },
            { soru: "Yeni bir kitaba başlamak istediniz. Bu kitap mesleğiniz veya kişisel gelişiminiz için de çok faydalı.", options: [ { text: "Okumak bana hep zor gelir, belki 1-2 sayfa bakarım sonra bırakırım.", puan: 1 }, { text: "Kitabı alırım ama öylece rafa koyarım, çok az okurum.", puan: 2 }, { text: "Günlük veya haftalık okuma hedefleri koyar, düzenli şekilde ilerlerim.", puan: 3 }, { text: "Bir an önce bitirmeye odaklanır, bazen gece uykusuz kalıp hemen tamamlamaya çalışırım.", puan: 4 }, { text: "Kitabı elime alınca başka hiçbir şeye vakit ayırmam, takıntılı şekilde bitiririm.", puan: 5 } ] },
            { soru: "Grup arkadaşlarınız, “Sen işleri hızlı hallediyorsun, bize de yardım et” diye talepte bulunuyorlar. Ancak özel zamanınızı da harcamanız gerekecek.", options: [ { text: "Kendi işime bile yeterince zaman ayıramıyorum, yardım teklifini kabul etmem.", puan: 1 }, { text: "İstiyorum ama üşengeçliğim yüzünden onlara fazla katkı veremem; yarım yamalak yardım ederim.", puan: 2 }, { text: "Uygun bir plan dâhilinde, elimden gelen yardımı yaparım ama kendimi de ihmal etmem.", puan: 3 }, { text: "Hayır diyemem, başkalarının işlerini de üstlenir, bazen kendime vakit kalmaz.", puan: 4 }, { text: "Kendimi kanıtlama isteğiyle herkesin işini ben yüklenirim; hatta kendi sınırlarımı aşarım.", puan: 5 } ] },
            { soru: "Bir projenin sonunda ödül veya büyük bir takdir alma ihtimaliniz var. Bu, sizi nasıl motive ediyor?", options: [ { text: "Ödül olsa da umurumda değil, çalışmak istemiyorum; tembellik ağır basıyor.", puan: 1 }, { text: "Kısa bir heves gelir ama çabuk söner; yine de fazla uğraşmayacağım.", puan: 2 }, { text: "Ekstra motivasyon sağlar ama çalışmamı planlı ve sürdürülebilir şekilde yaparım.", puan: 3 }, { text: "Hırslanır, tüm boş vakitlerimi projeye adar, diğer sorumluluklarımı ikinci plana iterim.", puan: 4 }, { text: "Ödül benim için her şey; kazanmak uğruna gece gündüz kendimi harap eder, tek amaç başarı olur.", puan: 5 } ] },
            { soru: "Patronunuz/öğretmeniniz size, “Performansın düşmüş, biraz daha gayret göstermelisin” dedi. Tepkiniz ne olur?", options: [ { text: "Zaten motivasyonum düşük, hiç uğraşamam, ‘Ne hâli varsa görsün’ derim.", puan: 1 }, { text: "Çabalasam mı diye düşünürüm ama genelde bahaneler bulur, tembelliğe devam ederim.", puan: 2 }, { text: "Eleştiriyi dikkate alır, çalışma planımı gözden geçirir, eksiklerimi düzeltmeye başlarım.", puan: 3 }, { text: "Kendimi kanıtlamak için ekstra mesaiye kalır, gerektiğinde tatilimi bile feda ederim.", puan: 4 }, { text: "Kendimi o kadar zorluyorum ki tükenme noktasına gelsem de durmam, sırf performans artsın diye her şeyi feda ederim.", puan: 5 } ] },
            { soru: "Uzun süredir üzerinde çalıştığınız bir görev var. Tamamladınız ama hâlâ “Daha iyi yapabilirdim” hissi içindesiniz.", options: [ { text: "Bitirmek bile mucizeydi, fazla enerjim yok, sıradaki işler de umurumda değil.", puan: 1 }, { text: "Belki biraz daha uğraşsam olurdu ama ‘Idare eder’ diyerek bırakırım.", puan: 2 }, { text: "Hedefimi gerçekleştirdim; yeterince gayret gösterdim, ufak tefek eksikler olabilir.", puan: 3 }, { text: "Yeniden düzenleme, düzeltme yaparak zamanımı artırır, mükemmel olana kadar uğraşırım.", puan: 4 }, { text: "Asla tatmin olmam, sürekli yeniden başa dönerek kendimi de ekibi de yıpratırım; bitmeyen bir mükemmeliyet arayışım var.", puan: 5 } ] },
            { soru: "Sosyal hayat (aile, arkadaş) ile iş/okul arasındaki dengeyi nasıl kurarsınız?", options: [ { text: "Zaten iş/okul için çok az çaba sarf ediyorum, çoğu zaman boş geziyorum, aile/arkadaş da umursamıyorum.", puan: 1 }, { text: "Bazen çalışsam da çoğu zaman keyfî şeylerle vakit geçirir, verimli olmam.", puan: 2 }, { text: "Program yaparak hem iş/okul hem sosyal yaşama vakit ayırmaya çalışırım; ne tembellik ne aşırı hırs.", puan: 3 }, { text: "Çoğunlukla iş/okul öncelikli, arkadaşlarla buluşmaları iptal etme pahasına kendimi kaptırırım.", puan: 4 }, { text: "Neredeyse ailemi, arkadaşlarımı tamamen unutur, sadece iş/okul başarısına odaklanırım.", puan: 5 } ] },
        ]
    },
    vesvese: {
        title: "Hayatı Sallayan Boşvermişlik mi, Uykuları Kaçıran Kuruntu mu?",
        concepts: { tefrit: "Umursamazlık", fazilet: "Tedbir", ifrat: "Vesvese" },
        questions: [
            { soru: "Önümüzdeki yıl için finansal planlama yapmanız gerekiyor. Maaş veya geliriniz sınırlı, ama giderleriniz de artabilir.", options: [ { text: "Hiç plan yapmam, ‘Ne olacaksa olsun’ der, elde avuçta para kalmamışsa da umursamam.", puan: 1 }, { text: "Plan yapmayı düşünürüm ama çoğunlukla erteler, ‘Nasıl olsa bir şekilde döner’ diye çok ilgilenmem.", puan: 2 }, { text: "Gelir-gideri kabaca hesaplar, bütçe planı hazırlar, gerekirse tasarruf yolları ararım.", puan: 3 }, { text: "Detaylı hesap defterleri tutar, olası her kötü senaryoyu kafamda büyütür, yedek bütçeler oluşturmaya çalışırım.", puan: 4 }, { text: "Geleceğe dair o kadar kaygılıyım ki gece gündüz hesap yapar, neredeyse korkudan para harcamayı keserim.", puan: 5 } ] },
            { soru: "Sağlık kontrolleri yapmak aklınıza geldi. Ufak tefek belirtileriniz olsa da büyük sorun olmayabilir.", options: [ { text: "Doktora gitmem, hafif ağrılar olsa da önemsemem, ilaç kullanmaya dahi üşenirim.", puan: 1 }, { text: "Bazen endişelensem de çoğunlukla ‘Geçer herhalde’ diye doktora gitmeyi ertelerim.", puan: 2 }, { text: "Düzenli periyotlarla kontrolden geçer, önemli belirtileri ciddiye alırım.", puan: 3 }, { text: "Azıcık semptom görsem bile doktora koşar, her olası hastalığa karşı tahlil isterim.", puan: 4 }, { text: "Her ağrıyı büyük bir hastalık sanır, sürekli test yaptırır, endişeden uyuyamam.", puan: 5 } ] },
            { soru: "Aracınızın lastiği biraz eski, uzun yola çıkacaksınız. Lastik patlama riski de var.", options: [ { text: "Ne bakımı ne değişimi, ‘Yolda ne olacaksa olsun’ der geçerim.", puan: 1 }, { text: "Belki değiştirmeliyim ama ‘Idare eder’ diye düşünür, herhangi bir önlem almadan yola çıkarım.", puan: 2 }, { text: "Lastik durumunu kontrol ettirir, gerekiyorsa değiştirir; yola öyle çıkmaya dikkat ederim.", puan: 3 }, { text: "Her ihtimale karşı yanımda yedek lastik, tamir kiti, hatta belki ekstra teker bile taşırım.", puan: 4 }, { text: "Lastiğin patlayacağını, büyük bir kazaya sebep olacağını sürekli düşünerek kafamda felaket senaryoları kurarım.", puan: 5 } ] },
            { soru: "Bir seyahat planlarken her detayı kontrol altına almak veya akışına bırakmak arasında tereddüt ediyorsunuz.", options: [ { text: "Plan yapmam, bilet-otel gibi detayları son ana kadar düşünmem; doğaçlama takılırım.", puan: 1 }, { text: "Kaba taslak bir rota belirlerim ama çoğu detaya hâkim olmadan ‘Nasıl olsa bir yol bulunur’ derim.", puan: 2 }, { text: "Ulaşım, konaklama, olası aksilikleri makul ölçüde planlayarak, esnek bir program yaparım.", puan: 3 }, { text: "En ufak ayrıntıyı bile hesaplar, ‘Şu saat şu vasıta, şu saat şu rezervasyon’ diye takvim doldururum.", puan: 4 }, { text: "Seyahatten önce bin türlü kötü ihtimal düşünüp neredeyse hiç keyif alamayacak kadar kaygıya kapılırım.", puan: 5 } ] },
            { soru: "Yeni bir projeye başlarken risk analizi yapma konusundaki yaklaşımınız?", options: [ { text: "Riske bakmam, ‘Olduğu kadar, olmadığı kader’ deyip girişirim.", puan: 1 }, { text: "Aklıma gelse de çoğu zaman derinlemesine analiz etmem, ‘boşver’ der geçerim.", puan: 2 }, { text: "Artı-eksi değerlendirmesi yapar, kontrol edilebilir risk varsa ilerlerim.", puan: 3 }, { text: "En ufak ihtimali bile göz önüne alır, bazen kararsızlığa düşecek kadar ince eleyip sık dokurum.", puan: 4 }, { text: "Riskler aklımdan çıkmaz, korkuya kapılır, sürekli ‘Ya başarısız olursam’ endişesiyle hareket ederim.", puan: 5 } ] },
            { soru: "Yakınınızın gecikmesi (örneğin randevuya geç kalması) size nasıl hissettirir?", options: [ { text: "Gelmezse gelmesin, hiç umursamam, üstünde durmam.", puan: 1 }, { text: "Biraz merak etsem de çok takmam, ‘Keyfi bilir’ diye düşünürüm.", puan: 2 }, { text: "Önce arar, gecikme sebebini sorarım; mantıklıysa beklerim, çok endişeye kapılmam.", puan: 3 }, { text: "Geç kalınca çabucak endişelenir, ‘Başı belada mı?’ diye hızlıca olumsuz düşünmeye başlarım.", puan: 4 }, { text: "Kesin kötü bir kaza veya felaket oldu diye paniğe kapılır, hemen en kötü senaryoyu kurarım.", puan: 5 } ] },
            { soru: "Eşyalarınız veya önemli belgeleriniz konusunda ne kadar koruyucu tedbir alırsınız?", options: [ { text: "Kaybolursa kaybolsun, çok da önemsemem; ne kilit ne kasa kullanırım.", puan: 1 }, { text: "Normal bir çekmece veya basit bir saklama yeter, fazladan güvenlik önlemi almayı pek düşünmem.", puan: 2 }, { text: "Önemli evrakları kilitli veya emniyetli bir yerde tutar, ara sıra kontrol ederim.", puan: 3 }, { text: "Sık sık kontrol eder, evde kasa, dijital şifre vb. gibi önlemleri de abartılı biçimde kullanırım.", puan: 4 }, { text: "Her an kaybolabilir paranoyası yaşar, en ufak evrakı bile kilitli kasalara koyar, sürekli kontrol ederim.", puan: 5 } ] },
            { soru: "Televizyonda veya haberlerde olumsuz bir gelişme (afet, kriz) duyunca tepkiniz?", options: [ { text: "Beni ilgilendirmez diye düşünür, aynı şekilde hayatıma devam ederim.", puan: 1 }, { text: "Biraz aklıma takılır ama hemen unuturum, ekstra tedbir filan almam.", puan: 2 }, { text: "Risk bana da gelebilir mi diye kısaca düşünür, gerekiyorsa ufak önlemler alırım.", puan: 3 }, { text: "Hemen detaylı bilgi araştırır, ‘Ya başıma gelirse?’ diye endişelenir, planlar yaparım.", puan: 4 }, { text: "Günlerce, haftalarca korkuyla yaşar, felaket senaryoları kurarak psikolojimi bozarım.", puan: 5 } ] },
            { soru: "Bir sunum ya da davet öncesinde hazırlık yapma biçiminiz nasıldır?", options: [ { text: "Doğaçlama geçerim, ‘Ne olursa olsun’ derim, hazırlığa zaman ayırmam.", puan: 1 }, { text: "Kafamda biraz taslak kurarım ama pek prova yapmam, ‘Idare eder’ diye düşünürüm.", puan: 2 }, { text: "Zamanımı ayırır, temel noktaları not alır, rahat bir hazırlık süreciyle dengeli çalışırım.", puan: 3 }, { text: "Detaylı hazırlık yapar, her ihtimale karşı yedek plan oluşturur, aşırı titizlenirim.", puan: 4 }, { text: "Geceleri uyumadan defalarca prova eder, hata yapma korkusuyla kendimi strese sokarım.", puan: 5 } ] },
            { soru: "Değerli eşyalarınız (telefon, cüzdan vb.) için önlem alıyor musunuz?", options: [ { text: "Nereye koyduğumu bile unuturum, kaybolursa da dert etmem.", puan: 1 }, { text: "Çantamda veya cebimde taşıyıp fazla düşünmem; kayıp ihtimaline kafa yormam.", puan: 2 }, { text: "Güvenli bir şekilde korur, dışardayken ara sıra kontrol ederim.", puan: 3 }, { text: "Sıkça cebimi/çantamı yoklar, ‘Yanımda mı?’ diye her an doğrulamak isterim.", puan: 4 }, { text: "Her dakika paranoid gibi kontrol eder, hatta ‘Eve dönsem de kasaya kilitlesem’ diye endişelenirim.", puan: 5 } ] },
            { soru: "Geceleri yatağa uzandığınızda aklınızdan geçen düşünceler?", options: [ { text: "Neredeyse hiçbir şeyi takmam, kafam rahattır, plan filan yapmam.", puan: 1 }, { text: "Bazen birkaç şeyi düşünür ama genelde ‘Yarın ola hayrola’ deyip uyurum.", puan: 2 }, { text: "Ertesi günün işlerini/planlarını kabaca gözden geçirir, normal bir dinginlikle uykuya dalarım.", puan: 3 }, { text: "Planlarımı detaylı düşünür, ‘Olumsuz bir şey olur mu?’ diye orta düzeyde kaygılanırım.", puan: 4 }, { text: "Vesvese yapar, felaket senaryoları kurar, bazen saatlerce kafamda endişelerle boğuşur uyuyamam.", puan: 5 } ] },
        ]
    },
    adalet: {
        title: "Zulme Boyun Büken mi, Gücüyle Ezen mi?",
        concepts: { tefrit: "Boyun Eğme", fazilet: "Adalet", ifrat: "Zulüm" },
        questions: [
            { soru: "Bir iş arkadaşınız, hata yaptığı halde suçu size yıkmaya çalışıyor. Üstünüz veya ekibiniz de bunu duyunca biraz size yükleniyor.", options: [ { text: "Haksız da olsa kabullenir, hiçbir savunma yapmadan boyun eğerim.", puan: 1 }, { text: "Biraz itiraz eder gibi olurum, ama yine de ‘Bana zarar vermesinler’ diye sessizce çekilirim.", puan: 2 }, { text: "Haklılığımı sakin bir şekilde açıklar, gerçekten hatam yoksa bunu ifade ederek düzeltmeye çalışırım.", puan: 3 }, { text: "Kendimi savunayım derken başkalarına da haksız ithamda bulunabilir, sözlerimi sertleştirebilirim.", puan: 4 }, { text: "Konuyu büyütür, asıl ben karşı tarafı suçlayarak haksız şekilde cezalandırmaya kalkarım.", puan: 5 } ] },
            { soru: "Arkadaş grubunuzda iki kişi tartışıyor ve biri bariz şekilde haksız davranıyor. Siz de bu grubun saygı duyulan bir üyesisiniz.", options: [ { text: "Karışmayayım, kavga büyürse bana da sıkıntı çıkar, haksızlığı bildiğim halde sessiz kalırım.", puan: 1 }, { text: "İçten içe rahatsız olurum ama araya girmeye cesaret edemem; uzak durmaya çalışırım.", puan: 2 }, { text: "Konuşmaya dahil olup haksızlığa uğrayanın yanında durur, tarafları uzlaştırmaya gayret ederim.", puan: 3 }, { text: "Haksızı uyarırken, bazen kırıcı laflar sarf edebilirim; öfkeli bir adalet uygulamaya kalkarım.", puan: 4 }, { text: "Güçlü tarafı destekleyip zayıfı ezmeyi tercih eder, kendi konumumu sağlama alırım.", puan: 5 } ] },
            { soru: "Bir yönetici pozisyonuna atandınız; size bağlı bir çalışan, performans raporlarında geride kalmışken, sizin yakın arkadaşınız olduğu için onu kayırma eğiliminiz var.", options: [ { text: "Güçlü ekibin karşısında durmayayım diye, adaletli bir değerlendirme yapmaktan bile çekinirim.", puan: 1 }, { text: "Aslında kayırmak istemem ama arkadaşımın hatırı için biraz torpil yaparım.", puan: 2 }, { text: "Tüm çalışanları objektif ölçütlerle değerlendirir, arkadaşım olsa dahi adil davranırım.", puan: 3 }, { text: "Adil olmaya çalışsam da canım sıkıldığında haksız cezalandırma veya fazla ödüllendirme yapabilirim.", puan: 4 }, { text: "Tamamen kendi menfaatime veya keyfime göre kayırma/cezalandırma uygular, hiçbir adalet gözetmem.", puan: 5 } ] },
            { soru: "Aile içinde bir paylaşım (miras, masraf vb.) söz konusu ve büyükler “Sen karışma, usul böyle” diyor. Ancak bariz şekilde birinin hakkı yeniyor.", options: [ { text: "Ailenin tepkisinden çekinip ses çıkarmaz, haksızlık gördüğüm halde kabul ederim.", puan: 1 }, { text: "Rahatsız olsam da aile büyüklerine itiraz etmekten korkarım, ufak bir uyarıyla geçiştiririm.", puan: 2 }, { text: "Saygıyı bozmadan, ‘Bu işin adil olması gerek’ diyerek konuyu mantıklı şekilde gündeme taşırım.", puan: 3 }, { text: "Haksızlığa karşı çıksam da bazen haklıyı savunurken üslubumu sertleştirip aileyi daha da gerebilirim.", puan: 4 }, { text: "Gücü elime geçirirsem ben de kendi lehime bir düzenleme yapar, başkalarının hakkını gasp ederim.", puan: 5 } ] },
            { soru: "Bir dostunuz, haksızlığa uğradığını ifade ederek sizden yardım istiyor. Karşı taraf da sizin tanıdığınız biri. Durumu tam bilmeden sizden “Şahit ol” talebi var.", options: [ { text: "Karışmam, her iki tarafa da ‘Ben hiç görmedim, bilmiyorum’ deyip uzak dururum.", puan: 1 }, { text: "Gördüğüm şeyleri bile gizleyebilirim; ‘Benim başım ağrımasın’ diye çekinceli davranırım.", puan: 2 }, { text: "Olup biteni bildiğim kadarıyla dürüstçe anlatır, kimin hakkı neyse onu teslim etmeye çalışırım.", puan: 3 }, { text: "Arkadaşım haklı olsa da bunu abartılı şekilde savunur, diğer tarafa sert veya haksız ithamda bulunabilirim.", puan: 4 }, { text: "Güçlü veya bana menfaat sağlayan tarafı kayırmak için gerçeği çarpıtarak yalancı şahitlik yaparım.", puan: 5 } ] },
            { soru: "Bir konuda üstleriniz ya da yöneticileriniz sizi haksız yere suçladı. Kendinizi savunma veya hak arama imkânınız var ama riskli görünüyor.", options: [ { text: "Hiçbir şey söylemem, ‘Böyle gelmiş böyle gider’ diyerek kabullenirim.", puan: 1 }, { text: "Ufak bir itiraz etmeye çekinir, en fazla ‘Ben masumum’ diyerek kısık sesle geçiştiririm.", puan: 2 }, { text: "Delillerle kendimi savunmaya çalışır, haksız ithamı ortadan kaldırma çabası gösteririm.", puan: 3 }, { text: "Haksızlığı düzeltirken saldırgan bir tutum takınır, bazen yöneticilerle ciddi çatışma çıkarırım.", puan: 4 }, { text: "Kendimi savunmakla kalmam, bu vesileyle karşı tarafı da her yönden suçlayarak onları haksız konuma düşürmeye uğraşırım.", puan: 5 } ] },
            { soru: "Toplum içinde bir otorite veya güç elinize geçti (ör. okul kulüp başkanlığı). Disiplin kurallarını nasıl uygulayacağınız size bağlı.", options: [ { text: "Hiçbir kuralı doğru düzgün uygulamaz, haksızlıklara göz yumarım, sırf kimse bana tepki göstermesin diye.", puan: 1 }, { text: "Bazı kuralları uygularım ama güçlü veya yakın olduğum kişilere torpil geçerim; tam adil olamam.", puan: 2 }, { text: "Kim olursa olsun kuralları makul ölçüde uygular, suçun cezasını adil biçimde belirlerim.", puan: 3 }, { text: "Adil olmaya çabalasam da zaman zaman gücün etkisiyle aşırı ceza verebilirim.", puan: 4 }, { text: "Gücümü keyfime göre kullanır, istediğimi cezalandırıp istediğimi kayırır, baskıcı bir yönetim uygularım.", puan: 5 } ] },
            { soru: "Evde, kardeşiniz veya çocuğunuz bir hata yaptı. Ceza verip vermemek size kalmış.", options: [ { text: "Ne kadar büyük hata olsa da ses çıkarmam, nasılsa ben karışamam diye pasif kalırım.", puan: 1 }, { text: "Biraz kızarım ama fazla üstüne gitmem, haksız olsa da neticeye karışmam.", puan: 2 }, { text: "Hatanın boyutuna göre makul bir yaptırım veya uyarı yapar, neden-sonuç anlatırım.", puan: 3 }, { text: "Bazen sinirlenir, büyük de olsa küçük de olsa gereğinden fazla ceza verme eğilimim olabilir.", puan: 4 }, { text: "Fırsat bulmuşken ezici bir ceza uygular, çocuğun/kardeşin haklarını hiçe sayabilirim.", puan: 5 } ] },
            { soru: "Bir sözleşme veya anlaşma masasında iki taraf arasındaki adaletsiz maddeleri fark ettiniz. Taraflar “Sessiz kal, işimize karışma” diyor.", options: [ { text: "Susup geçerim, benimle alakası yok, kim ne yaparsa yapsın.", puan: 1 }, { text: "İçten içe rahatsızlık duyarım ama yine de korkudan veya çekinceden sesimi çıkaramam.", puan: 2 }, { text: "Gücüm yeterse ‘Bu madde çok haksız, düzeltelim’ diyerek iyileştirme için araya girerim.", puan: 3 }, { text: "Adaleti savunayım derken sert bir üslup kullanır, bazen ortamı gerebilir, kazançlı tarafı öfkeyle suçlayabilirim.", puan: 4 }, { text: "Ben de bu fırsattan yararlanır, kendi menfaatime denk düşen haksız şartları bilerek görmezden gelirim.", puan: 5 } ] },
            { soru: "Sizin yüzünüzden mağdur olan biri varsa (istemeden de olsa zarar vermişsiniz), nasıl davranırsınız?", options: [ { text: "Özür dilesem bile çok çekinirim; genelde kaçınma yoluna gider, telafi edemem.", puan: 1 }, { text: "Kısmen sorumluluğu kabul eder gibi yapar, kısa bir özürle geçiştiririm, pek telafiye kalkışmam.", puan: 2 }, { text: "Mağduriyeti gidermek için elden geleni yapar, zararı tazmin etmeye çalışır, özür dilerim.", puan: 3 }, { text: "Telafi etmek istesem de bazen kibirlenip ‘O da dikkat etseydi’ gibi bahanelere sığınabilirim.", puan: 4 }, { text: "Zarar verdiğim kişiyi önemsiz görür, ‘Kendi suçu!’ deyip haksızlığa devam ederim.", puan: 5 } ] },
            { soru: "İşyerinde/okulda yönetim size “Değerlendirme” (not, puan, terfi dağıtımı vs.) görevi verdi. Bazıları size yakın, bazıları uzak.", options: [ { text: "Değerlendirme yapmaktan kaçar, korkarım ki haksızlığa uğrayan olursa beni suçlarlar.", puan: 1 }, { text: "Tanıdığım insanlara torpil yaparım, diğerlerini de görmezden gelir, tatsızlık olmasın diye biraz kayırma yaparım.", puan: 2 }, { text: "Herkesi aynı ölçütlerle değerlendirir, kıdem/başarı/katkı gibi objektif kriterlere bakarım.", puan: 3 }, { text: "Genelde objektif olmaya çalışsam da sevmediklerime daha düşük not vermeye eğilimli olabilirim.", puan: 4 }, { text: "Keyfime göre dağıtır, yakınlarımı göklere çıkarırken, sevmediklerimi ezmek için fırsat bilirim.", puan: 5 } ] },
        ]
    },
    hikmet: {
        title: "Cevher Olan Aklı Köreltiyor musun, Yoksa Hilebazlığa mı Koşturuyorsun?",
        concepts: { tefrit: "Gabâvet", fazilet: "Hikmet", ifrat: "Cerbeze" },
        questions: [
            { soru: "Tartışma sırasında yeni bir bilgi öğreniyorsunuz. Deliller ortada, ama sizinle çelişiyor.", options: [ { text: "Hiç sorgulamadan eski inancımı sürdürür, yeni bilginin ne dediğini anlamamaya uğraşırım.", puan: 1 }, { text: "Kısmen anlasam da derinlemesine incelemekle uğraşmam, yüzeysel kalırım.", puan: 2 }, { text: "Delilleri değerlendirir, doğruyu anlamaya çalışır, fikirlerimde gerekirse revizyona giderim.", puan: 3 }, { text: "Bilgiyi kavrarım ama bazen kendimi haklı çıkarmak için laf cambazlığı yaparak kullanırım.", puan: 4 }, { text: "Gerçek önemsiz, ben bu bilgiyi karşı tarafı manipüle etmek için fırsat bilirim; hilekârca davranırım.", puan: 5 } ] },
            { soru: "Yeni bir yöntem veya teknoloji öğrenmek üzeresiniz. Oldukça karmaşık ve teorik altyapı da gerektiriyor.", options: [ { text: "Detayını merak etmem, ezbere taklit ederim; mantığını sorgulamam.", puan: 1 }, { text: "Yüzeysel bakarım, ‘Kullanıyorsam yeter’ der, derin teorik kısmı önemsemeden geçerim.", puan: 2 }, { text: "Nasıl çalıştığını anlamaya, fayda-zarar analizini yapmaya ve bilinçli kullanmaya dikkat ederim.", puan: 3 }, { text: "Teknolojiyi öğrenir, çoğu zaman kendi avantajıma olacak şekilde sunar ama gerçeği bazen saklarım.", puan: 4 }, { text: "Zekâmı kullanarak başkalarını saf dışı bırakacak hileler geliştirir, fırsat bulursam manipüle ederim.", puan: 5 } ] },
            { soru: "Bir proje için ekiple bilgi toplama aşamasındasınız. Sizden beklenen, doğru ve güvenilir kaynakları derlemeniz.", options: [ { text: "Kim ne diyorsa olduğu gibi alırım, kaynaksız verileri bile sorgulamadan projeye koyarım.", puan: 1 }, { text: "Kısmen kaynak bakarım ama çoğu zaman yüzeysel araştırmayla yetinirim.", puan: 2 }, { text: "Gerçekçi ve doğrulanabilir bilgileri seçer, gerekirse farklı kaynakları karşılaştırırım.", puan: 3 }, { text: "Verileri toplarken, ekibin bilmesini istemediğim noktaları saklar veya eğip bükerim.", puan: 4 }, { text: "Proje menfaatim için yanıltıcı/veri manipülasyonu yapar, rakip ekiplere fark atmayı düşünürüm.", puan: 5 } ] },
            { soru: "Arkadaş grubunuzda bir tartışma var. Siz gerçeği biliyorsunuz ama sırf kazanan olmak için mantıksal oyunlar yapmaya niyetlisiniz.", options: [ { text: "Ne gerçeği ne oyunu; aklımı yeterince kullanmam, duyduğumu tekrar ederim.", puan: 1 }, { text: "Biraz fikir beyan ederim ama tam derinliğiyle anlamadan çabucak konu değiştirmeye çalışırım.", puan: 2 }, { text: "Hakikati açıklamak için bilgi ve mantığımı yapıcı şekilde kullanır, tarafsız kalarak meseleyi aydınlatırım.", puan: 3 }, { text: "İkna etmek için ufak laf cambazlıklarına başvurabilir, asıl gerçeği bazen gizleyebilirim.", puan: 4 }, { text: "Benim amacım kazanmak; doğru veya yanlış fark etmez, zekâmı manipülasyon için kullanırım.", puan: 5 } ] },
            { soru: "İş hayatında stratejik planlamaya ihtiyacınız var. Rakip firmayla ilgili istihbarat toplama fırsatı doğdu, etik açıdan riskli.", options: [ { text: "Plan yapmam, rastgele davranırım; rakip ne yapıyor hiç merak etmem.", puan: 1 }, { text: "Biraz ilgilenirim ama derin analiz veya etik kuralları umursamam, yüzeysel kalırım.", puan: 2 }, { text: "Rakibin stratejisini meşru yöntemlerle öğrenmeye çalışır, kendi planımı akılcı ve dürüst şekilde kurarım.", puan: 3 }, { text: "Gerekirse etik dışı yollara kısmen girer, avantaja sahip olmak için ufak hileler kullanabilirim.", puan: 4 }, { text: "Her türlü yasa dışı/ahlak dışı istihbarat toplayarak, rakibi alt etmek adına zekâmı hileye seferber ederim.", puan: 5 } ] },
            { soru: "Size bir proje sunumu yapıldı. Mantıklı görünüyor ama bazı noktalar belirsiz. Takım “Hemen kabul edelim” diye baskı yapıyor.", options: [ { text: "Sorgulamadan ‘Tamam’ der, ayrıntısına bakmam; ekibi de takip etmem.", puan: 1 }, { text: "Bir-iki soru sorsam da pek üzerine gitmem, yüzeysel onaylarım.", puan: 2 }, { text: "Eksik veya riskli kısımları öğrenmek için akılcı sorular sorar, netleştikten sonra karar veririm.", puan: 3 }, { text: "Soruları akıllıca yöneltirim ama yine de kendi kârım varsa ekibi yanıltacak şekilde yorumlar da yapabilirim.", puan: 4 }, { text: "Proje sunumundaki belirsizlikleri bilerek kullanır, ileride şahsi çıkarıma döndürmek için kurnaz planlar yaparım.", puan: 5 } ] },
            { soru: "Bir arkadaş sizden “Danışmanlık” istiyor, hayatıyla ilgili önemli bir konuda rehberlik bekliyor.", options: [ { text: "Ne yapsa yapsın, pek düşünmeden rastgele birkaç tavsiye söylerim.", puan: 1 }, { text: "Kısmen yardımcı olmaya çalışırım ama derinlemesine analiz etmem, ‘Sen bilirsin’ der geçerim.", puan: 2 }, { text: "Onu dinleyerek mantıklı tavsiyelerde bulunur, kendi durumuna uygun çözüm yolları öneririm.", puan: 3 }, { text: "Danışmanlık yaparken kendi avantajımı gözetebilir, belki onun çıkarına tam uygun olmayan önerileri de verebilirim.", puan: 4 }, { text: "Tamamen manipülasyon odaklı; onun zaaflarını kullanıp asıl kârı ben elde edeyim diye hileli öğütler veririm.", puan: 5 } ] },
            { soru: "Sosyal medyada tartışma. Elinizde karşı tarafı rezil edebilecek bir argüman var ama doğruyu yansıtmayabilir.", options: [ { text: "Nasılsa doğru-yanlış fark etmeden konuşurlar, ben de sessiz kalır, düşünmem.", puan: 1 }, { text: "Az biraz katılır, bir iki laf atar, ama fazla uğraşmadan çekilirim.", puan: 2 }, { text: "Bilgiyi doğru şekilde paylaşır, varsa eksik noktayı düzeltir, dürüstçe katkı sunarım.", puan: 3 }, { text: "Karşı tarafı alt etmek için argümanımı biraz çarpıtarak kullanır, zaferi öncelerim.", puan: 4 }, { text: "Doğruluğu umurumda değil, sırf karşıyı rezil etmek adına zekâyı istismar eder, yalan-yanlış argümanlar da üretirim.", puan: 5 } ] },
            { soru: "Bir lisans veya sertifika sınavındasınız. Zor bir test, “Hile yapma” imkânınız olsa rakipsiz başarı kazanabilirsiniz.", options: [ { text: "Çalışmıyorum da, hile de yapmıyorum, zaten ne olursa olsun.", puan: 1 }, { text: "Çalışsam da pek derine inmiyorum; hile fikri aklımdan geçse de tam cesaret edemem.", puan: 2 }, { text: "Emek vererek öğrenir, adil bir sınavla hak ettiğim sonucu almak isterim.", puan: 3 }, { text: "İyi çalışırım; yine de ihtiyaç görürsem ufak kopya veya taktik hilelere başvurabilirim.", puan: 4 }, { text: "Direkt kopya, sızıntı vb. bütün imkanları kullanır, rakipleri geride bırakmak için ne gerekirse yaparım.", puan: 5 } ] },
            { soru: "Arkadaşlarınız “Çok zekisin, sen bize yol göster” diyor. Size danışıyorlar ama siz bazen kendiniz için bunları araç olarak kullanmak istiyorsunuz.", options: [ { text: "Zekâ falan kullanmam, ne diyorsam rastgele söylerim, düşünmeye üşenirim.", puan: 1 }, { text: "Düşünürüm ama yüzeysel öneriler veririm; derin akıl yürütme zahmetine pek girmem.", puan: 2 }, { text: "Onlara gerçekten fayda sağlayacak rasyonel çözümler sunar, dürüst biçimde rehberlik ederim.", puan: 3 }, { text: "Mantıklı öneriler verse de kendi çıkarım için gizli yönlendirmeler yapmaktan çekinmem.", puan: 4 }, { text: "Başkalarının bana duyduğu güveni tamamen manipüle eder, kendi kârım için onların zararını bile göze alırım.", puan: 5 } ] },
            { soru: "Bir konuyu bilip bilmediğinizi soruyorlar; gerçekte tam hâkim değilsiniz, ama “yarım yamalak bilgim var.”", options: [ { text: "Ezberci şekilde, derin mantık olmadan rastgele cevap veririm, gerçeği öğrenmeye çalışmam.", puan: 1 }, { text: "Çok da ilgilenmem, ‘Bilmiyorum ama belki böyledir’ diye yüzeysel konuşup bırakırım.", puan: 2 }, { text: "Bildiğim kadarını açıklar, ‘Tam emin değilim, daha araştırmak lazım’ diyerek dürüstçe sınırlarımı söylerim.", puan: 3 }, { text: "Bilenmiş izlenimi verip eksik bilgimi saklar, bazen ‘laf cambazlığı’ ile durumu idare ederim.", puan: 4 }, { text: "Kendimi çok bilgili gösterir, bilmediğim hâlde sanki uzmanmış gibi konuşur, insanları yanıltırım.", puan: 5 } ] },
        ]
    },
    iffet: {
        title: "Nefsinin Sesi Kısık mı, Çığlıkları Tavan mı?",
        concepts: { tefrit: "Humud", fazilet: "İffet", ifrat: "Fücur" },
        questions: [
            { soru: "Yeme-içme konusunda kendinize ne kadar izin verirsiniz? Farz edelim ki sevdiğiniz yemek çeşitleri var ama sağlığınız veya dinî hassasiyetleriniz de önemli.", options: [ { text: "Neredeyse aç gezer, kendimi gereksiz yere çok kısıtlarım; lezzetli bile olsa yemem.", puan: 1 }, { text: "Arada keyifli şeyler yesem de genelde kendime ‘Gerek yok’ deyip tatsız menülerle yetinirim.", puan: 2 }, { text: "Zaruri ihtiyaç ve lezzeti dengeler, helal ve sağlıklı çizgide ölçülü tüketirim.", puan: 3 }, { text: "Bazen aşırı yemek yiyerek abartırım, tatlı veya ağır yemeklere direnmem zor olabilir.", puan: 4 }, { text: "Canım ne isterse sınırsız yerim, sağlık veya helal-haram gibi kaygıları ikinci plana atarım.", puan: 5 } ] },
            { soru: "Karşı cinse duyduğunuz ilgi/duygu söz konusu olduğunda genel tutumunuz nedir?", options: [ { text: "Kendimi tamamen kapatır, duygusal veya fiziksel yakınlıktan kaçınırım, hatta meşru da olsa soğuk davranırım.", puan: 1 }, { text: "İlgi duysam da bastırır, ‘Zaten gereksiz’ diye karşı cinsle iletişimimi minimumda tutarım.", puan: 2 }, { text: "Helal dairede, dinî ve ahlâkî ölçülere sadık kalarak ilişkiyi yürütür, kontrolü elden bırakmam.", puan: 3 }, { text: "Sık sık duygusal ataklar yaşar, tutkumu bazen frenleyemem, flört veya yakınlığı abartabilirim.", puan: 4 }, { text: "Her türlü yasağı, sınırı reddeder; cinsel veya duygusal isteklerimi doyurmaktan asla çekinmem.", puan: 5 } ] },
            { soru: "Giyim-kuşam ve süslenme konusundaki yaklaşımınız?", options: [ { text: "Kendime bakmayı dahi gereksiz görür, en basit veya eski kıyafetle idare ederim, güzellik/temizlik umurumda değil.", puan: 1 }, { text: "Arada düzgün giyinirim ama çoğunlukla kendimi saklar, dış görünüşü iyice basite indirgerim.", puan: 2 }, { text: "Temiz, özenli ve ölçülü giyinmeye dikkat eder, ne aşırı gösterişe ne de özensizliğe kaçmam.", puan: 3 }, { text: "Modayı ve dikkat çekici tarzları sever, bazen abartılı süslenip insanları cezbetmeye çalışırım.", puan: 4 }, { text: "Tamamen gösterişli, kimi zaman mahremiyet sınırlarını da ihlal eden, başkalarını tahrik edecek kadar aşırı giyinirim.", puan: 5 } ] },
            { soru: "Arkadaşlar bir eğlence mekânına davet ediyor. Müzik, dans, belki gece kulübü… Sınırları zorlayan ortamlara karşı tavrınız?", options: [ { text: "Asla eğlenceye gitmem, meşru da olsa ‘Hepsi gereksiz’ diye düşünürüm.", puan: 1 }, { text: "İstemesem de bazen uğrarım ama çoğunlukla köşede oturur, keyif almamaya çalışırım.", puan: 2 }, { text: "Eğer mekân ve içerik İslami-ahlâkî ölçülerimi çok aşmıyorsa gidip ölçülü şekilde eğlenebilirim.", puan: 3 }, { text: "Ortama uyup dansa, müziğe kaptırabilirim; sınırları aşsam da çok pişman olmam.", puan: 4 }, { text: "Her türlü ortama açığım, ekstrem veya haram eğlence de dâhil, özgürce sınırsız zevk ararım.", puan: 5 } ] },
            { soru: "İltifat, övgü, beğenilme gibi duygusal ihtiyaçlar konusunda tavrınız?", options: [ { text: "Beğenilmek ve iltifat almak bana anlamsız gelir; kendimi neredeyse değersiz göstermekten bile çekinmem.", puan: 1 }, { text: "Beğenilsem de rahatsız olur, ‘Gerek yok, benim neyim var ki’ diye duygularımı bastırırım.", puan: 2 }, { text: "Takdir edilmek tabii ki hoş; ama bu konuda asla aşırı beklentiye girmem, ölçüyü korurum.", puan: 3 }, { text: "Beğenilme isteğim yüksek, bazen sırf övgü almak için normalden fazla uğraşabilirim.", puan: 4 }, { text: "Sürekli ilgi ve övgü ister, bunu elde etmek uğruna haysiyet veya sınır tanımam.", puan: 5 } ] },
            { soru: "Helal-haram konusundaki hassasiyetiniz genellikle nasıldır?", options: [ { text: "Helal olan şeyleri bile kendime yasaklayacak kadar aşırı kısıtlama yaparım.", puan: 1 }, { text: "Geniş olan helal dairede bile soğuk kalır, meşru nimetlerden çoğunlukla kaçınırım.", puan: 2 }, { text: "İslam’ın helal-haram çizgisine uyup, helalde özgürce yaşar, haramdan sakınmaya dikkat ederim.", puan: 3 }, { text: "Helale riayet etsem de zaman zaman harama da kayabilir, nefsi isteklerimi frenlemekte zorlanırım.", puan: 4 }, { text: "Haram-helal ayrımı gözetmeden canım ne isterse yapar, keyif ve arzu odaklı yaşarım.", puan: 5 } ] },
            { soru: "Reklamlar, kampanyalar ve cazip teklifler karşınıza çıktığında tüketim alışkanlığınız?", options: [ { text: "Hemen hemen hiçbir şeye para harcamaz, ihtiyaç bile olsa ‘Hayır’ derim.", puan: 1 }, { text: "Nadiren ufak tefek alırım, ama genelde ‘İhtiyaç değil’ deyip kendimi baskılarım.", puan: 2 }, { text: "Gerçek ihtiyacımı tanır, bütçeme göre hareket ederim; faydalıysa alırım, gereksizse almam.", puan: 3 }, { text: "Bazen heveslenir, abartılı alışveriş yapar, sonradan ‘Keşke almasaydım’ diye pişman olurum.", puan: 4 }, { text: "Çılgınca alışveriş yapar, lüks ve keyif için paramı esirgemem, tatminsizce daha fazlasını isterim.", puan: 5 } ] },
            { soru: "Arkadaş ortamında hafif flört, şakalaşma veya mizah sınırlarını aşan bir sohbet varsa, tutumunuz nedir?", options: [ { text: "Toplumsal / dini geleneklere uygun da olsa her türlü etkileşimden kaçar, ‘Böyle şeylere gerek yok’ derim.", puan: 1 }, { text: "Ara sıra bulunurum ama hiç katılmam, soğuk ve mesafeli davranırım.", puan: 2 }, { text: "Helal ölçüler dâhilindeyse hoşgörüyle katılır, rahatsız edici boyuta gelince kırıcı olmadan uyarırım.", puan: 3 }, { text: "Bazen sınırı aşan şakalara veya flörte kapılıp gidiyor, nefsimi kontrol etmekte zorlanıyorum.", puan: 4 }, { text: "Sınır tanımadan her türlü müstehcen veya sakıncalı espriye/eğlenceye dahil olur, aşırılıktan çekinmem.", puan: 5 } ] },
            { soru: "Maddi imkânlarınızı nefsânî hazlara harcama eğiliminiz?", options: [ { text: "Kendime hiçbir keyif, eğlence veya konfor izni vermem, sürekli mahrum bırakırım.", puan: 1 }, { text: "Zaman zaman ufak harcamalar yapsam da genelde çok cimrice yaklaşıp hevesimi öldürürüm.", puan: 2 }, { text: "Kendimi makul ölçüde ödüllendirir, fazla lüksten kaçınırım; ölçü her zaman belli.", puan: 3 }, { text: "Nefsimin istediği şeyleri karşılayayım derken bazen abartılı masraflara giriyor, dengeyi kaçırıyorum.", puan: 4 }, { text: "Keyfî harcamalarla yetinmeyip, bütün kazancımı lükse, eğlenceye veya aşırıya harcarım; nefsime sınırsız davranırım.", puan: 5 } ] },
            { soru: "Öfke, cinsel arzu, haz gibi güçlü dürtülerinizde kontrol mekanizmanız nasıl işliyor?", options: [ { text: "Bu dürtüleri tamamen yok etmeye çalışır, kendimi sanki hissiz hale getirmek isterim.", puan: 1 }, { text: "Dürtülerim olsa da genelde bastırırım, ‘Kendime yasaklayayım’ deyip aşırı kısıtlamaya giderim.", puan: 2 }, { text: "Doğal arzularımı meşru yollarla tatmin eder, aşırıya kaçmadan kendimi disipline ederim.", puan: 3 }, { text: "Zaman zaman nefsime yenilip hırslı, öfkeli, tutkuyla hareket eder, sonradan pişman olurum.", puan: 4 }, { text: "Dürtülerime anında boyun eğer, haram veya aşırılık varsa bile ‘Banane’ derim.", puan: 5 } ] },
            { soru: "Nefs terbiyesi (manevi gelişim) kavramına bakışınız?", options: [ { text: "Nefsimi adeta yok edip, meşru hazlardan bile uzak durmaya çalışırım; her şeye katı yasak koyarım.", puan: 1 }, { text: "Terbiye etmek adına kendimi aşırı baskılarım, belki helal keyiflerden de sürekli kaçarım.", puan: 2 }, { text: "Nefsimi tanır, meşru isteklerini makul düzeyde karşılar, haram ve aşırılıktan sakınırım.", puan: 3 }, { text: "Nefs terbiyesini arada hatırlar ama sık sık kendimi kaptırır, aşırılıklara da girebilirim.", puan: 4 }, { text: "Nefs terbiyesiyle uğraşmayı gereksiz bulur, her arzumun peşinden koşarım; ‘Hayat kısa’ mantığıyla yaşarım.", puan: 5 } ] },
        ]
    },
    ihlas: {
        title: "Hayırdan Uzak mı Kaçıyorsun, Yoksa Alkış Avcısı mısın?",
        concepts: { tefrit: "Terk-i Amel", fazilet: "İhlâs", ifrat: "Riya" },
        questions: [
            { soru: "Bir dostunuz size “Filanca hayır organizasyonunda gönüllü arıyoruz, gel bizimle katıl” dedi. Ama bu organizasyona katılırsanız insanlarla iç içe olacaksınız ve belki “Gösteriş mi yapıyorum?” endişeniz var.", options: [ { text: "Böyle işlere hiç bulaşmam. Ya riyaya düşersem diye korkuyorum; en iyisi hiç hayır işi yapmayayım.", puan: 1 }, { text: "İçimden gelmese de mecburen bir görünüp kaçarım; ‘göstermelik de olsa katılayım’ diye yapsam da sonuna kadar kalamam.", puan: 2 }, { text: "Hayrı, Allah rızası için yapmak isterim. İnsanların övmesi ya da yermesi ikinci planda; elimden geldiğince organizasyonda hizmet ederim.", puan: 3 }, { text: "Katılma fikri hoş, ancak aklımın bir köşesinde ‘Orada insanlara da gözükeyim, takdir alırım’ düşüncesi var. Bu niyetle biraz da heveslenirim.", puan: 4 }, { text: "Ben zaten insanların beğenisine bayılırım; hayır işine katılırsam çevremde ‘Ne kadar iyi adam!’ diyecekler, tam aradığım fırsat.", puan: 5 } ] },
            { soru: "Bir sabah namazına kalktınız. Cemaatle namaza gitmek aklınızda. Ancak mescidde görecek olanların övgüsü veya “Ne kadar dindar!” demeleri sizi cezbediyor. Kafanız karışık.", options: [ { text: "Kalbimde riyadan korktuğum için namaza hiç gitmeyeyim daha iyi; evde de kılmamaya kadar varır bu korku, belki de vakti kaçırırım.", puan: 1 }, { text: "Arada bir gidiyorum ama mescitte övülmekten hoşlanıyorum. Yine de gönülsüz oluyorum; tam içtenlikle değil.", puan: 2 }, { text: "Niyetimi düzeltip ‘Allah rızası’ diyerek cemaatle kılarım. Övülmek veya yargılanmak benim için pek kıymetli değil.", puan: 3 }, { text: "Aslında istiyorum ki etraftakiler beni görsün. Namaza elbette Allah rızası için de gidiyorum, ama beğeni almak da cazip geliyor.", puan: 4 }, { text: "‘İnsanlar beni görsün, ne takva adam!’ desinler diye namaza giderim. Yoksa normalde gitmezdim.", puan: 5 } ] },
            { soru: "Çevrenizdekiler “Bazı insanlar zekât veriyor gibi gösteriyor ama gizlice vermiyor, sen de dikkat et” diyor. Sizin finansal durumunuz elverişli, zekât vermeniz gerek. Nasıl yaklaşırsınız?", options: [ { text: "Zaten bu konulardan hep kaçıyorum, zekâtı da kimseye vermem, ‘Ya riya olur, ya başka sorun çıkar’ diye tümüyle terk ederim.", puan: 1 }, { text: "Biraz versem de tam miktarı eksik çıkarırım, göstermelik olsun yeter. Ya da verip vermediğim bile belirsiz.", puan: 2 }, { text: "Zekât benim farz borcum. Allah rızası için, gizliden de verebilirim; kim ne düşünürse düşünsün.", puan: 3 }, { text: "Zekâtımı versem de illa etrafa çok anlatmam ama içimden ‘Bilsinler de beni takdir etsinler’ diye isteyebilirim.", puan: 4 }, { text: "Zekât miktarını abartarak ilan ederim; gerçekte belki daha az verip insanlara büyük gösteririm. Gösterişi seviyorum.", puan: 5 } ] },
            { soru: "Dini bir sohbet veya ilmî programa katılıyorsunuz. Programın sonunda konuşmacı, “Bu programa devam edenler çok takdir ediliyor, rızıklanıyor” diyor. Siz de orada görüneceksiniz.", options: [ { text: "Samimiyetim yoksa hiç gitmeyeyim. Zaten ben öğrenmek, amel etmek gibi konulardan soğudum.", puan: 1 }, { text: "Arada gidip yüz göstermeyi yeterli buluyorum; çok istikrarlı değilim, ama yine de ‘Görünsün’ istiyorum.", puan: 2 }, { text: "Burada faydalı ilim var. Maksadım hakikati öğrenmek, Allah rızasına yakınlaşmak. Övgü veya çıkar beklentim yok.", puan: 3 }, { text: "Hem istifade ederim hem de çevremde ‘Ne kadar dindar, sürekli sohbette’ gibi bir izlenim yaratmak hoşuma gider.", puan: 4 }, { text: "Asıl niyetim, ‘Orada beni ön sıralarda görsünler, fotoğraf çekilsin, paylaşılsın’ diyerek göstermek.", puan: 5 } ] },
            { soru: "Bir öğrenci, hocanızdan övgü almak için sizden yardım istiyor: “İşi sen yap, benim adım çıksın.” Sizin açınızdan bakarsak, bu işin sevabı/iyiliği de bir nevi paylaşılamayacak. Nasıl tepki verirsiniz?", options: [ { text: "Ben zaten böyle şeyleri yapmıyorum. İyi iş, proje vs. neyse hiç bulaşmam. Samimi olamam diye korkuyorum.", puan: 1 }, { text: "Yaparım belki, ama içimden ‘Bari hoca beni de takdir etse’ diye bir beklentim olsa da zayıf kalırım.", puan: 2 }, { text: "Amelimi sadece Allah bilir; insanlara gösteriş gerekmeden yardımcı olurum. Hocanın övmesi ya da görmemesi fark etmez.", puan: 3 }, { text: "İçten içe ben de takdir almak isterim. ‘Ben yapsam da belki hocaya duyurabilirim’ diyerek perde arkası kendimi göstermeye çalışırım.", puan: 4 }, { text: "Yardım ediyorsam mutlaka adım anılsın isterim, yoksa yapmam. Bütün şan benim üzerime olsun diye uğraşırım.", puan: 5 } ] },
            { soru: "Sosyal medyada dini içerikli paylaşımlar yaparken, içten içe beğeni sayısına odaklandığınızı fark ettiniz. Bu durum sizi nasıl etkiler?", options: [ { text: "Ben zaten böyle hiçbir paylaşım yapmam, dindar görünmekten korkar, paylaşımdan uzak dururum.", puan: 1 }, { text: "Arada dinî bir söz veya ayet paylaşıyorum ama aslında beğeni bekliyorum, tam içtenlikli değilim.", puan: 2 }, { text: "Paylaşımımda asıl amaç, Allah’ın mesajını veya güzellikleri duyurmak. Beğeni alıp almamak çok da önemli değil.", puan: 3 }, { text: "Beğeniler hoşuma gidiyor, her ne kadar Allah rızası için de yaptığımı söylesem, takdirin cazibesi var.", puan: 4 }, { text: "Tek amacım, ‘Dindar, bilgili’ görünmek. Paylaşımları tamamen insanları etkilemek için yapıyorum.", puan: 5 } ] },
            { soru: "Bir ibadet (mesela oruç veya gece namazı) ile meşgulsünüz. Ama ailenize/arkadaşlarınıza bunu anlatıp kendinizi yüceltmek istiyorsunuz. Kafanızda nasıl bir süreç olur?", options: [ { text: "Böyle yüksek amellere gerek yok, oruç veya gece namazından korkuyorum, nefsen yapamıyorum, tamamen bırakırım.", puan: 1 }, { text: "Arada yaparım, insanlara da biraz söylerim. Ama tam motive olmadığım için bazen yarım kalır.", puan: 2 }, { text: "İbadeti elimden geldiğince gizli tutar, Allah için yaparım. Kimseye anlatmak gerekmez, anlatırsam da riyayı beslememeye dikkat ederim.", puan: 3 }, { text: "Yaparken aklıma ‘Bunu yarın sohbet ortamında söylerim’ düşüncesi geliyor, övgü bekliyorum.", puan: 4 }, { text: "Zaten bu ameli sırf başkalarına anlatmak için yapıyorum. Duyanlar ‘Maşallah, ne takva!’ desin diye uğraşıyorum.", puan: 5 } ] },
            { soru: "Toplu bir iftar organizasyonunda görev alıyorsunuz. Sunuculuk veya servisi üstlenmek size düştü. Aklınızdan “Beni görsünler” gibi düşünceler geçiyor mu?", options: [ { text: "Ben hiç görev almam, belki de riyaya düşerim. En iyisi uzak durmak.", puan: 1 }, { text: "Zorunlu olsa da yaparım, ama gönülsüzüm. Belki faydası olur, ama ‘şov’ yapacak cesaretim de yok.", puan: 2 }, { text: "Hizmette bulunduğum için mutlu olur, Allah rızası niyetiyle elimden geleni yaparım. İnsanların bakışı ikinci planda.", puan: 3 }, { text: "Görev yaparken ‘Keşke herkes beni övse, ne fedakâr’ dese’ diye içten içe bekliyorum.", puan: 4 }, { text: "Bütün işim, herkesin gözü önünde rol kesmek; gerçekte hizmet etmeye değil, görünmeye çalışıyorum.", puan: 5 } ] },
            { soru: "Bir kardeşiniz ya da arkadaşınız, “Namazda yoğunlaşamıyorum; sen nasıl bu kadar düzenli kılıyorsun?” diye sordu.", options: [ { text: "Ben zaten düzenli değilim, hatta namazı çoğu kez bırakırım. Korkum samimi olamamak. Bu yüzden kaçıyorum.", puan: 1 }, { text: "Aslında tam düzenli değilim ama ona ‘Evet, hep kılarım’ diye biraz abartırım. Niyetim net değil.", puan: 2 }, { text: "Ben ne yapıyorsam elimden geldiğince Allah için yaparım. Ona da samimiyeti anlatır, kendimi parlatmadan normal şekilde paylaşırım.", puan: 3 }, { text: "Hemen ‘Ben şöyle yapıyorum, böyle yapıyorum’ deyip kendimi övme eğilimine girerim.", puan: 4 }, { text: "Hangi namazı kıldığımı bile abartır, süsleyerek anlatırım. Tamamen gösteriş davasındayım.", puan: 5 } ] },
            { soru: "Maddi bir yardım kampanyasında isminizin ilan edilmesi veya afişe yazılması fikrine nasıl yaklaşırsınız?", options: [ { text: "İsmim ilan edilecekse hiç bağış yapmam, tamamen uzak dururum. Genel olarak böyle işlere girmem.", puan: 1 }, { text: "Az bir şey verip ismime bakılsın isterim; aslında çok da gönülden istemiyorum ama işte öyle bir heves var.", puan: 2 }, { text: "Gerekliyse gizli veya açıktan verebilirim; niyetim Allah rızası. Reklam benim için önemli değil, fayda önemli.", puan: 3 }, { text: "İsmimi görsünler hoşuma gider. Tamamen niyetim bu değil ama yine de ‘Varlığımı bilsinler’ diye hevesliyim.", puan: 4 }, { text: "Ana motivasyonum isminin billboard’da yazılması. Yoksa yardım falan düşünmem, illaki duyurulmak isterim.", puan: 5 } ] },
            { soru: "Çevreniz sizden “Dua et, senin duan kabul oluyor” gibi şeyler söyleyerek sürekli sizi övüyor. Nasıl tepki verirsiniz?", options: [ { text: "Böyle lafları duyunca her duayı bırakırım. ‘Ben samimi olamam, en iyisi hiç dua etmeyeyim’ diye düşünürüm.", puan: 1 }, { text: "Biraz hoşuma gider, ‘Evet, dualarım kabul olur’ diyerek tam da bilmediğim hâlde onlara öyle sunarım.", puan: 2 }, { text: "Teşekkür eder, ‘Her şey Allah’ın takdiri, ben sadece kulum’ diyerek mütevazı kalırım.", puan: 3 }, { text: "İnsanların ‘Maşallah ne veli kişi!’ demesi nefsimi okşar, duamda rıza-i İlahi aramak kadar beğenilmek de sevindirir.", puan: 4 }, { text: "Oh, tam istediğim şey: ‘Ben özelim, duam da makbuldür!’ diye hava atarım, sırf gösteriş ve beğeni beklerim.", puan: 5 } ] },
        ]
    },
    hased: {
        title: "Başkasının Başarısı Sence Yok mu, Yoksa Göz mü Diktiğin Var?",
        concepts: { tefrit: "Kayıtsızlık", fazilet: "Gıpta", ifrat: "Hased" },
        questions: [
            { soru: "Bir arkadaşınız yeni işinde büyük başarı kazandı, terfi etti. Nasıl bir hisle yaklaşıyorsunuz?", options: [ { text: "Hiç umurumda değil, ne hali varsa görsün. Onun başarısı da başarısızlığı da bana fark etmez.", puan: 1 }, { text: "Kısmen seviniyorum ama içimde de ‘Ne yapsa ne etse bana ne…’ diye ilgisizim.", puan: 2 }, { text: "Tebrik ederim ve ‘Çalışkan olduğundan başardı. Umarım ben de emek verip güzel sonuçlar alırım’ diye heveslenirim.", puan: 3 }, { text: "İçten içe kıskançlık hissediyor, ‘Keşke o kadar öne çıkmasaydı’ diye rahatsız oluyorum, yine de tam açık edemiyorum.", puan: 4 }, { text: "Hem kıskanıyorum hem de ‘Keşke terfisi iptal olsa, ben onun yerine geçsem’ diyorum. Nimetinin gitmesini arzuluyorum.", puan: 5 } ] },
            { soru: "Arkadaş grubunda bir kişi, çok yetenekli. Farklı alanlarda ödüller alıyor. Sizin yeteneğiniz ise ortalama. Tepkiniz?", options: [ { text: "Hiç önemsemem, belki ‘İyi halt etti’ deyip geçerim, kendimi geliştirme gayreti bile hissetmem.", puan: 1 }, { text: "Az biraz takdir ederim ama ‘Ben de öğreneyim’ hevesim pek yok, kendi hâlime devam.", puan: 2 }, { text: "Onun başarısı beni motive eder; ‘Ben de çalışırsam benzer ilerleme kaydedebilirim’ diye heveslenirim.", puan: 3 }, { text: "İçimde ‘Of, neden benim bu yeteneğim yok! Onunki keşke bu kadar parlamasaydı’ gibi kıskançlık kabarıyor.", puan: 4 }, { text: "Tam anlamıyla onun başarısını çekememek, ‘Keşke bu yetenek onda hiç olmasaydı’ diye hınç duymak.", puan: 5 } ] },
            { soru: "Bir aile ferdiniz (kardeşiniz, kuzeniniz) yeni bir araba aldı. Oldukça kaliteli ve pahalı. Siz eski model araba kullanıyorsunuz.", options: [ { text: "Umurumda değil. Yeni araba alsa da bana ne, bakmam bile.", puan: 1 }, { text: "Fena değil ama benim için çok da kıymeti yok, benzerine sahip olmayı düşünmem.", puan: 2 }, { text: "Onu tebrik eder, kendime de nasip olmasını dilerim. Çalışarak elde edebileceğimi düşünüp gayrete gelirim.", puan: 3 }, { text: "Kıskanmaya başlarım, ‘Niye ben böyle kalıyorum, onda var, bana haksızlık’ diye iç geçirim.", puan: 4 }, { text: "İçten içe ‘Keşke arabası bozulsun, ben de alabilsem’ veya ‘Gösterecek hâli kalmasın’ diye negatif duygu beslerim.", puan: 5 } ] },
            { soru: "İş veya okul ortamında bir proje sunuldu; en başarılı kişi, büyük ödül alacak. Siz de katılıyorsunuz ama şu an geridesiniz. Diğerlerinin başarısı karşısında ne hissediyorsunuz?", options: [ { text: "Ödülmüş, yarışmaymış... Banane. Kendimi bile zor motive ediyorum, kimin kazandığı da ilgimi çekmiyor.", puan: 1 }, { text: "Yarışta onlar öne geçince ‘Hmm iyi’ derim, çok ilgilenmem. Belki biraz dair olsam da umursamayabilirim.", puan: 2 }, { text: "Öne geçeni alkışlar, ben de çalışmamı artırırım. Kazanırsa sevincine ortak olurum, ben de öğrenirim.", puan: 3 }, { text: "Onların önde olması içimi kıpırdatıyor ama negatif yönde, ‘Off, keşke ilerlemese’ diye sıkılıyorum.", puan: 4 }, { text: "Tam bir çekememezlik hissiyle, ‘İnşallah proje çöker’ gibi gizli temennilerde bulunuyorum.", puan: 5 } ] },
            { soru: "Yakın çevrenizde biri çok cömert ve hayırda ileri, topluma faydalı işler yapıyor. Çevre de onu övüyor, siz ise kendinizi geride hissediyorsunuz.", options: [ { text: "Ne cömertliği ne yardımı... Banane. İnsanları umursamıyorum.", puan: 1 }, { text: "Biraz takdir ederim ama kendim de öyle bir gayrete girmeye niyetlenmem.", puan: 2 }, { text: "Tebrik eder, ‘Ben de imkân buldukça yardım etmeliyim’ diye heveslenirim.", puan: 3 }, { text: "Rahatsız olurum, ‘Herkes onu övüyor, beni övmüyor’ diye kıskançlık duyarım.", puan: 4 }, { text: "‘O kadar hayır yapmasa da ben öne çıksam’ şeklinde hased duygusuyla kıvranırım.", puan: 5 } ] },
            { soru: "Bir tanıdığınız, üniversite sınavında çok yüksek puan aldı. Siz orta düzeyde puan aldınız. Aileniz de sürekli onu örnek gösteriyor.", options: [ { text: "Umursamam, bana kimse örnek gösterse de takmam, benim yolum ayrı.", puan: 1 }, { text: "Kısa bir kıskançlık gelir ama çabucak ‘Ne hâli varsa görsün’ der, kendi hâlime dönerim.", puan: 2 }, { text: "‘Maşallah, ben de çalışsam daha iyi puan alabilirim’ diyerek moral ve hedef belirlerim.", puan: 3 }, { text: "Kendi kendime ‘Şanslıymış, ben de yapabilirdim!’ diye söylenip hafif kıskançlık hissederim.", puan: 4 }, { text: "İçten içe ‘Keşke puanı iptal olsa! Ben daha iyi görünebilsem’ türü zararlı kıskançlık hissi duyuyorum.", puan: 5 } ] },
            { soru: "Özel bir yeteneğiniz yok diye düşünüyor, etrafınızda marifetli insanları “fazla parlıyorlar” diye mi görüyorsunuz?", options: [ { text: "Sıfır ilgi duyarım, herkes parlasa da beni etkilemez, ben aynıyım.", puan: 1 }, { text: "Bazen heves etsem de çok geçmeden bırakırım, ‘Bende yetenek yok’ diye kayıtsız kalırım.", puan: 2 }, { text: "Yetenekli insanları gördükçe, kendi potansiyelimi keşfetmek için çaba gösterir, olumlu esin alırım.", puan: 3 }, { text: "Kendimi onlardan düşük gördüğüm için hasedim kabarır, ama tam dile getiremem.", puan: 4 }, { text: "Resmen hasetlik, ‘Neden bende yok, keşke onda da olmasa’ diyerek hınç besliyorum.", puan: 5 } ] },
            { soru: "Başkasının sosyal medyada gördüğünüz başarılı paylaşımları (spor, sanat, okuldaki başarı, evlilik haberi vb.) sizde hangi duyguyu tetikler?", options: [ { text: "Geçer giderim, incelerim belki ama içimde en ufak kıpırtı olmaz, ‘Banane!’ derim.", puan: 1 }, { text: "Biraz hoşuma gider, bazen de ‘Ne güzel, ama bana ne’ diye önemsemem.", puan: 2 }, { text: "‘Aferin, ben de ilgi duyduğum alanlarda çabalarsam böyle başarı elde edebilirim’ diye gaza gelirim.", puan: 3 }, { text: "Kıskanır, o paylaşımları kapatırım. İçten içe ‘O kadar övgüyü hak etmiyor’ diye rahatsız olurum.", puan: 4 }, { text: "Öfkeyle ‘Ondan gitsin, boşa çıksın!’ gibi olumsuz düşüncelerle hased duyarım.", puan: 5 } ] },
            { soru: "Kardeşiniz bir ödül kazandı; aileniz de ona daha çok ilgi ve sevgi gösteriyor gibi hissediyorsunuz.", options: [ { text: "Ailemi de kardeşimi de umursamıyorum. Beni ne kadar severler, sevmezler, önemli değil.", puan: 1 }, { text: "Epey bir duygusuz kalırım ama arada ‘Eh, ona da böyle davranıyorlar’ diyerek hafif bozulurum.", puan: 2 }, { text: "Seviniyor, onu tebrik ediyor, belki ben de öyle bir başarı yakalayabilirim diyerek olumlu kıskançlık (gıpta) hissediyorum.", puan: 3 }, { text: "Anneme-babama belli etmesem de ‘Bu kadar abartmayın, o kadar da büyük iş değil’ diyerek kıskançlıktan homurdanırım.", puan: 4 }, { text: "Kardeşimin ilgisinin kesilmesi, ödülünün geri alınması falan gibi kötü dileklerle hasedimi besliyorum.", puan: 5 } ] },
            { soru: "Bir ihtiyacınız var; aynı ihtiyacı bir tanıdığınız karşılamış, çok mutlu. Siz ise hâlâ çözemediniz.", options: [ { text: "Kimin ne ihtiyacı giderilmiş, kimin mutlu olduğu umurumda değil; ben kendi dertlerimle bile ilgilenmiyorum.", puan: 1 }, { text: "Fena değil ama ben de elde etsem mi diye düşünsem de çabayı göze almıyorum.", puan: 2 }, { text: "Onu görünce ‘Ne güzel, ben de çaba göstermeliyim, imkân varsa çalışayım’ diye motive olurum.", puan: 3 }, { text: "İçimde rahatsızlık var, ‘O elde etmiş, ben niye hâlâ yokum? Haksızlık’ diye kıskanıyorum.", puan: 4 }, { text: "Resmen diyorum ki ‘O da kaybetsin, ben de bulamadım diye o da mutlu olmasın.’ Hasetle doluyum.", puan: 5 } ] },
            { soru: "Uzun zamandır çabaladığınız bir sınavı, siz geçemediniz ama yakın bir arkadaşınız geçti.", options: [ { text: "Açıkçası kimin geçtiği, kimin kaldığı… Pek umursamıyorum. Geçtim varsay, geçmedim varsay.", puan: 1 }, { text: "Aferin diyerek geçiştiririm, içimde ne heyecan ne kıskançlık var, sanki bana çok uzak.", puan: 2 }, { text: "Tebrik eder, başarısını takdir ederim. ‘Ben de inşallah tekrar çalışıp başarabilirim’ diye olumlu ders alırım.", puan: 3 }, { text: "‘Keşke o da geçemeseydi, tek ben değil...’ gibi kıskanç duygu hissederim, ama yüzüne belli etmem.", puan: 4 }, { text: "Tam hased: ‘Başarısı gözüme batıyor, lütfen bir şekilde iptal olsun, haksız elde etmiş olsun’ vb. çirkin temenniler kuruyorum.", puan: 5 } ] },
        ]
    },
    sabir: {
        title: "Oturduğu Yerde Kalan mı, Sabırla İlerleyen mi, Yoksa Kestirmeden Koşup Tökezleyen mi?",
        concepts: { tefrit: "Atâlet", fazilet: "Sabır", ifrat: "Acelecilik" },
        questions: [
            { soru: "Uzun soluklu bir proje yaptığınızda, zorluklar ve pürüzler oluşuyor. Ne yaparsınız?", options: [ { text: "Proje zorlaşıyorsa tamamen bırakırım, ‘Ben zaten uğraşacak enerjide değilim’ derim.", puan: 1 }, { text: "Başta biraz denerim, sıkıntı görünce kenara çekilirim, ‘Bana göre değilmiş’ diyerek vazgeçerim.", puan: 2 }, { text: "Sorunları tespit eder, sabırla çözüm yolları arar, hemen pes etmem. Mantıklı bir süreç yönetirim.", puan: 3 }, { text: "Sonuç görmeyince hırslanıp telaş ederim, belki ekibi de bunaltırım, ‘Hemen bitirmeliyiz!’ derim.", puan: 4 }, { text: "Anında sonuç olmayınca öfkelenir, sabırsız biçimde herkesin üstüne gider, verimsizce projenin tadını kaçırırım.", puan: 5 } ] },
            { soru: "Uzun vadeli bir sınav ya da spor antrenmanı gerektiriyor: haftalarca çalışmak lâzım. Motivasyonunuz nasıl şekillenir?", options: [ { text: "Hiç girişmemeyi tercih ederim, ‘Zaten kazanamam, o kadar sabır yok bende’ diyerek atâlete düşerim.", puan: 1 }, { text: "Başlar gibi olsam da her zorlu aşamada bırakırım; düzenli çalışma huyum yok, sabredemem.", puan: 2 }, { text: "Plan yapar, gün gün çalışırım. Zor gelse de sabreder, motivasyonu korurum.", puan: 3 }, { text: "Başta çok hırslı başlarım ama yeterince hız alamayınca sabırsızlanır, çabuk pes veya öfke krizlerine girerim.", puan: 4 }, { text: "Hemen sonuç beklediğim için spor programını iki katına çıkarır, sakatlanabilir veya bunalarak mantıksızca acele ederim.", puan: 5 } ] },
            { soru: "Aileniz/arkadaşlarınız “Şu hedef için biraz sabır göster, hemen olmayabilir” diyor. Sizinse beklemeye tahammülünüz kısıtlı veya hiç yok.", options: [ { text: "Zaten bekleyemeyeceğim, hiç başlamayayım. Bu iş uzun sürecekse yokum.", puan: 1 }, { text: "Biraz dener, daraldığım an ‘Ben bu sabır işini beceremem’ diye uzaklaşırım.", puan: 2 }, { text: "Kolay olmayacağını bilsem de adım adım ilerlerim, sabır ve çalışmayı dengeli götürürüm.", puan: 3 }, { text: "Beklerken huzursuz olur, sürekli çevreme baskı yaparım, sabırsızca sonuca koşarım.", puan: 4 }, { text: "Israrlı şekilde ‘Hemen olmalı!’ diye dayatır, asla beklemeye yanaşmam; her şeyi hızlandırmak isterken belki de büsbütün bozabilirim.", puan: 5 } ] },
            { soru: "Okul/iş yerindeki bir proje uzun vadeli, sizi çok bunaltıyor. Bazı arkadaşlar sabrediyor, siz ne yaparsınız?", options: [ { text: "Kesinlikle projeden çekilir, ‘Uğraşamam ben’ derim, belki hiç başlamam.", puan: 1 }, { text: "Kısa denemeler yapsam da sıkıldıkça ‘Bırak gitsin’ deyip dağılırım.", puan: 2 }, { text: "Zorluk normaldir, belli bir emek ister; sabırla programlarım, yılmadan devam ederim.", puan: 3 }, { text: "Çabuk sonuç için arkadaşlara yüklenir, hızlı ilerlemek ister, sabırsızca ekibi bıktırabilirim.", puan: 4 }, { text: "Öylesine acele edip hatalara sürükler, proje ortada kalınca da agresifleşirim.", puan: 5 } ] },
            { soru: "Günlük hayatta beklenmedik bir iş: Ev taşıma, tamirat gibi... Uzun sürecek bir süreç. Sabır gerekiyor.", options: [ { text: "Hiç ilgilenmem, belki bir kenarda oturur, nasılsa bitmeyecek diye atâlete kapılırım.", puan: 1 }, { text: "Başlasam da çabuk bırakır, ‘Olmuyor, benlik iş değil’ deyip geri çekilirim.", puan: 2 }, { text: "Planlı şekilde uğraşır, gerektiği kadar vakit ve enerji ayırır, sabırla sonuna kadar götürürüm.", puan: 3 }, { text: "Kısa sürede bitirmek için aşırı stres yapar, kendimi ve çevremi sık boğaz ederim, sabırsızım.", puan: 4 }, { text: "Hızlı olsun diye her şeyi üst üste yığar, belki eşyaları kırar/dökebilirim; bunalımlı bir acelecilik içinde.", puan: 5 } ] },
            { soru: "Uzun süredir beklediğiniz bir terfi veya onay var. Kurum henüz sonuç açıklamadı. Siz ne hissediyorsunuz?", options: [ { text: "‘Bekleme zahmeti bana göre değil’ diyerek işi de, süreci de bırakma eğilimim var.", puan: 1 }, { text: "Biraz merak etsem de sonuç alamadıkça kendi hâlime döner, motivasyonu keserim.", puan: 2 }, { text: "Sürecin normal olduğunu düşünür, işimi yapmaya devam eder, sonuç için sabırlı davranırım.", puan: 3 }, { text: "Sürekli arayıp ‘Ne oldu, sonuç nerede?’ diye baskı yapar, bekleme sürecinde öfkelenirim.", puan: 4 }, { text: "Sabrım yok, ‘Bana hemen açıklayın!’ diye belki tehdit veya fevri davranışlara bile girerim.", puan: 5 } ] },
            { soru: "Maddi sıkıntıdasınız, ama birikim yapmak da zaman alacak. Uzun vadeli tasarruf planına yanaşıyor musunuz?", options: [ { text: "Birikim filan uzak iş, nasılsa olmuyor, her şeyi boşveririm.", puan: 1 }, { text: "Azıcık denesem de çabucak ‘Param yetmiyor, birikim mümkün değil’ deyip vazgeçerim.", puan: 2 }, { text: "Ağır da olsa her ay ufak ufak kenara koyar, sabırla devam ederim. Zamanla düzeleceğine inanırım.", puan: 3 }, { text: "Kısa sürede büyük meblağ biriktirmek ister, sabırsızca kendimi aşan kısıtlamalar yapar, belki de aileyi zora sokarım.", puan: 4 }, { text: "Ben bu beklemeyle uğraşamam; acele borç bulur, riskli işlere girer, büyük ihtimalle zarara uğrarım.", puan: 5 } ] },
            { soru: "Evde ebeveyn/akraba bakımı gibi uzun süren bir görev üstlendiniz. Sabır gerektiren bir süreç.", options: [ { text: "Hemen kaçayım. Bakım, sabır, ilgilenme işleri bana göre değil; atâlete kapılırım.", puan: 1 }, { text: "Biraz destek olsam da sıkılınca bırakırım, tamamen sürdüremem.", puan: 2 }, { text: "Zorluk olduğunu biliyorum, ama emek ve sabırla bu sorumluluğu üstlenirim, süreç içinde planlı davranırım.", puan: 3 }, { text: "Çabuk iyileşsin, anında sonuca varalım diye bazen sinirlenir, sabırsız tepkiler veririm.", puan: 4 }, { text: "İyileşmiyor diye agresifleşir, fevri davranışlarla moral bozucu ortam yaratırım.", puan: 5 } ] },
            { soru: "Bir ibadet (mesela oruç) tuttuğunuzda ilk birkaç saat sabredip sonra hızla bırakma veya ‘hemen aç olayım’ hissi yaşıyor musunuz?", options: [ { text: "Hiç oruca girmem, ‘Nasıl olsa yapamam’ diye en başta vazgeçiyorum.", puan: 1 }, { text: "Başlasam da daha öğlene gelmeden ‘Bırakayım’ deyip dayanamıyorum.", puan: 2 }, { text: "Zorluğunu bilsem de sabredip gün sonuna kadar gayret ederim, normal bir ibadet disipliniyle yaklaşırım.", puan: 3 }, { text: "Oruç tutarken bile ‘Hadi akşam gelsin!’ diye sürekli saate bakar, sabırsızlıkla çevreme sıkıntı veririm.", puan: 4 }, { text: "Sürekli huysuzlanır, ‘Niye bu kadar uzun?’ diye öfke edip belki ortada orucu bozabilirim.", puan: 5 } ] },
            { soru: "Bir toplu yolculukta otobüs rötar yapıyor, saatlerce beklemek gerek. Diğerleri bir şekilde sabrediyor. Siz?", options: [ { text: "İlgilenmem, yolculuğu da iptal eder, ‘Ne haliniz varsa görün’ der giderim.", puan: 1 }, { text: "Biraz beklerim ama çabuk sıkılırım, ‘Ben dayanamam’ deyip ortada kalırım.", puan: 2 }, { text: "Uzun bekleme de olsa gayet sakince, belki kitap okuyarak veya başka meşguliyetle sabırla beklerim.", puan: 3 }, { text: "Dakikada bir ‘Ne zaman kalkacağız!’ diye söylenir, sinirli tavırlar gösteririm.", puan: 4 }, { text: "Görevlilerle kavga etme noktasına gelir, sabırsızlıkla ortalığı karıştırırım, abartılı tepki veririm.", puan: 5 } ] },
            { soru: "Sosyal ilişkilerde de sabır gerekiyor (örneğin yeni tanıştığınız biriyle anlaşmak, zaman tanımak). Nasıl davranırsınız?", options: [ { text: "Yeni tanışma, zaman verme gibi şeyler uğraştırıyor; hiç ilişki kurmam, atâlet içinde dururum.", puan: 1 }, { text: "Başta girişir, sonra ‘O beni anlamıyor’ deyip çabuk pes ederim.", puan: 2 }, { text: "İnsan ilişkileri zamana bağlı; olgunlukla, sabırla uyum sağlamaya gayret ederim.", puan: 3 }, { text: "Karşımdakinden hızlı uyum beklerim, sabırsızca ‘Niye hemen anlaşamıyoruz?’ diye sitem ederim.", puan: 4 }, { text: "Acelecilikle ‘Hemen samimi olmalıyız veya hiç!’ diyerek aşırı tepkiler verip ilişkileri bozabilirim.", puan: 5 } ] },
        ]
    },
    hilm: {
        title: "Duygusuz Heykel mi, Korku Saçan Fırtına mı?",
        concepts: { tefrit: "Donukluk", fazilet: "Hilm", ifrat: "Öfke Patlaması" },
        questions: [
            { soru: "Bir arkadaşınız size haksızlık ediyor. Normalde tepki vermek gerek, ama siz ne yapıyorsunuz?", options: [ { text: "Zerre kadar tepki göstermem, içimden de rahatsız olmam, donuk kalırım; hak savunmak aklıma bile gelmez.", puan: 1 }, { text: "Rahatsız olurum ama yine de ‘Boşver’ der, sessiz kalırım.", puan: 2 }, { text: "Sakin, nazik ama net bir şekilde ‘Bu yaptığın doğru değil’ diyerek kendimi savunurum. Bağırıp çağırmam.", puan: 3 }, { text: "Hemen sertleşir, belki bağırırım ama yine de kavgaya tümüyle girmeyebilirim.", puan: 4 }, { text: "Anında büyük öfke patlaması: bağırma, hakaret veya fiziksel tehdit ile karşılık veririm.", puan: 5 } ] },
            { soru: "Trafikte biri size çarptı. Kusurlu olan o. İlk refleksiniz?", options: [ { text: "Umursamam, arabadan bile inmem, kaza mı oldu, olmadı mı önemsemem. Tepki yok.", puan: 1 }, { text: "Canım sıkılır ama olayı büyütmemek için sessizce kenara çekilir, kısmi diyalog kurarım.", puan: 2 }, { text: "Trafik kuralınca tutanak, sigorta vs. mantıklı prosedür neyse onu uygular, kavga etmeden çözmeye çalışırım.", puan: 3 }, { text: "Sinirlenir, bağırıp çağırır, ama yine de sonradan sakinleşebilirim.", puan: 4 }, { text: "Bir anda alevlenir, küfür veya fiziki itiş kakışla öfkemi boşaltırım.", puan: 5 } ] },
            { soru: "Bir haksız eleştiriye maruz kaldınız, sosyal medyada adınız geçiyor. Öfkeniz nasıl açığa çıkıyor?", options: [ { text: "Sanki hiçbir şey olmamış gibi davranır, cevap bile yazmam; duyarsız kalırım.", puan: 1 }, { text: "İçten içe rahatsız olup minimal bir cevap veririm, çok üstüne gitmem.", puan: 2 }, { text: "Nazik ve mantıklı bir şekilde gerçeği anlatır, hakaret etmeden kendimi savunurum.", puan: 3 }, { text: "Sert bir dille karşılık verir, kalp kırıcı sözlerle cevap yazarım.", puan: 4 }, { text: "Tam bir öfke patlamasıyla hakaretler, tehditler, belki troll hesaplarla saldırı planı yaparım.", puan: 5 } ] },
            { soru: "Evde ufak bir tartışma: Yemek istediğiniz gibi yapılmamış. Tepkiniz?", options: [ { text: "Hiç tepki göstermem, hatta memnuniyetsizliğimi bile dile getirmem, donukum.", puan: 1 }, { text: "Biraz hoşnutsuz olsam da ‘Neyse’ deyip geçerim.", puan: 2 }, { text: "‘Ellerine sağlık, ama keşke şöyle olsaydı’ diyerek normal, yumuşak bir ifadeyle belirtirim.", puan: 3 }, { text: "Anında ses yükseltip sinirlenir, belki birkaç kırıcı laf söylerim ama hemen de pişman olurum.", puan: 4 }, { text: "Masayı dağıtmaya kadar giden, aşırı öfke krizi yaşarım, ortalığı birbirine katarım.", puan: 5 } ] },
            { soru: "Bir arkadaşın size küstahça konuştu, belki biraz aşağılayıcı söz etti. Tepkiniz?", options: [ { text: "Hiçbir şey olmamış gibi sessiz kalırım; içimde de pek duygu uyanmıyor, donuk.", puan: 1 }, { text: "Bozulurum ama yine de yüzüne vuramam, uzaklaşırım sadece.", puan: 2 }, { text: "Yanlışlığını anlatır, gerekirse mesafemi koyarım ama hakaret veya taşkınlık yapmam.", puan: 3 }, { text: "Bağırıp onu da aşağılayacak sertlikte konuşurum.", puan: 4 }, { text: "Anında patlayarak ağır hakaret, fiziksel kavga gibi kontrolsüz bir öfke gösteririm.", puan: 5 } ] },
            { soru: "Spor müsabakasında hakem bariz haksız karar verdi, siz veya takımınız mağdur oldu.", options: [ { text: "Hiç tepki göstermem, haksız olsa da umursamam, oyundan da çıkarım belki.", puan: 1 }, { text: "Rahatsız olsam da hafifçe itiraz eder, fazla üstelemem.", puan: 2 }, { text: "Hakeme saygı çerçevesinde itiraz eder, kural dahilinde hakkımı ararım; bağırıp küfretmem.", puan: 3 }, { text: "Yüksek sesle itiraz, hakemin üstüne yürümek, belki saha içinde sert tavır göstermek.", puan: 4 }, { text: "Hakem veya rakiplerle kavgaya tutuşma, fiziksel şiddet, sahayı karıştıracak boyutta öfke patlaması.", puan: 5 } ] },
            { soru: "Çocuğunuz (veya küçük bir yakınınız) evin duvarına kalemle çizikler yaptı. Normalde uyarı gerek. Sizin tutumunuz?", options: [ { text: "Hiç umursamam, çocuk istediğini yapsın; kızmak aklıma gelmez.", puan: 1 }, { text: "Üzerinde durmam, belki ‘Yapma’ der ama ciddiye almam.", puan: 2 }, { text: "Sakince neden yanlış olduğunu anlatır, yapmaması için mantıkla uyarırım, cezalandırmadan öğretirim.", puan: 3 }, { text: "Kızar, belki bağırıp ‘Bir daha yaparsan çok fena olur’ diye korkuturum.", puan: 4 }, { text: "Öyle sinirlenirim ki çocuğa bağırıp, sert şekilde cezalandırır hatta vururum.", puan: 5 } ] },
            { soru: "Patron/hoca size fazla iş yüklemesi yaptı, siz de haklısınız ama her zamankinden çok daha öfke hissediyorsunuz.", options: [ { text: "Karşı çıkmam, hatta gayet tepkisiz kalırım, ‘Tamam’ deyip geçerim. İçimde de fazla duygu yok.", puan: 1 }, { text: "Biraz rahatsız olurum ama ‘Ne yapayım’ deyip sineye çekerim, belki kendi kendime söylenirim.", puan: 2 }, { text: "‘Bu fazla, lütfen makul düzeye çekelim’ diye kibar, mantıklı şekilde konuşurum, gerilimi yükseltmem.", puan: 3 }, { text: "Hemen ‘Bu haksızlık!’ diye ses yükseltir, öfkeli biçimde patrona/hocaya çıkışabilirim.", puan: 4 }, { text: "Ofisi basıp kavgaya varan, belki hakaret, tehdit gibi uç davranışlar sergileyecek kadar öfke patlar.", puan: 5 } ] },
            { soru: "Bir toplu organizasyonda görevlisiniz. İhmalkârlık sonucu aksaklık yaşandı, ortamdakiler sizi suçluyor.", options: [ { text: "Hiç tepki göstermeden sıyrılırım, sanki ben yokmuşum gibi davranırım.", puan: 1 }, { text: "Suçlu olmadığımı kısık sesle belirtirim ama baskı görünce susarım.", puan: 2 }, { text: "Gerekliyse özür diler veya durumu izah eder, saldırganlaşmadan gerçeği anlatmaya çalışırım.", puan: 3 }, { text: "Yüksek sesle kendimi savunur, ‘Asıl siz hatalısınız!’ diyerek ortamı gererim.", puan: 4 }, { text: "Bağırıp çağırıp etrafa hakaretler yağdırır, belki masaları tekmelerim; tam bir öfke patlaması.", puan: 5 } ] },
            { soru: "Arkadaş çevresinde bir ‘sözlü sataşma’ yaşandı, size de ithamlar var. Tepkiniz?", options: [ { text: "Tek kelime etmeden köşeye çekilir, umursamam; duygusuz kalırım.", puan: 1 }, { text: "Biraz rahatsız olup sessiz bir şekilde gruptan uzaklaşırım.", puan: 2 }, { text: "Haksız ithamı sakince reddeder, saygılı ve net bir üslupla konuyu açıklığa kavuşturmaya çalışırım.", puan: 3 }, { text: "Sesimi yükseltir, belki karşımda kim varsa onu ithamlarla karşı saldırıya geçerim.", puan: 4 }, { text: "Çıldırır gibi tepki verir, kavgaya tutuşur, ortalığı birbirine katarım.", puan: 5 } ] },
            { soru: "Özel bir eşyaya (telefon, bilgisayar) zarar verildi. Birisi kazayla kırdı.", options: [ { text: "Zerre umursamam, sanki hiç sorun değil gibi davranırım.", puan: 1 }, { text: "İçten üzülürüm ama yüksek tepki vermem, ‘Neyse…’ diyerek geçerim.", puan: 2 }, { text: "Karşı tarafı incitmeden, zararın telafisini sakince konuşur, aşırıya kaçmam.", puan: 3 }, { text: "Bir hayli sert konuşur, ona bunu ödetmeye zorlarken öfke sergilerim.", puan: 4 }, { text: "O an sinir krizi geçirir, fiziksel veya sözlü şiddet gösteririm.", puan: 5 } ] },
        ]
    },
    kanaat: {
        title: "Parayı Saklayıp Kendini de Mahrum mu Bırakıyorsun, Yoksa Harcarken Doymuyor musun?",
        concepts: { tefrit: "Pintilik", fazilet: "Kanaat", ifrat: "Tamah" },
        questions: [
            { soru: "Maaş veya harçlık aldığınız ilk gün, nasıl harcama veya davranış sergilersiniz?", options: [ { text: "Derhal kenara koyar, kendime bile harcamaktan çekinirim; gerekirse çok zor şartlarda yaşarım.", puan: 1 }, { text: "Temel ihtiyaçtan bile kısarım, mümkün mertebe hiç masraf etmemeye gayret ederim.", puan: 2 }, { text: "Önce zorunlu giderleri karşılar, küçük bir birikim veya tasarruf yapar, dengeli kullanırım.", puan: 3 }, { text: "Hemen daha çok kazanma hırsıyla plan yapar veya biriktirdiğimi de çarçur edebilecek heveslere kapılabilirim.", puan: 4 }, { text: "Anında lüks, pahalı veya gereksiz alışverişe dalar, paramı hızla tüketir; doyumsuzca harcayıp bitiririm.", puan: 5 } ] },
            { soru: "Arkadaşlarınız bir yardım kampanyası düzenliyor; sizden de katılım bekleniyor. Maddi katkı veya efor gerekebilir.", options: [ { text: "Asla para vermem; malım, param gereksiz yere azalmasın. Hatta mecbur hissetsem de vermem.", puan: 1 }, { text: "Zorunlu kalırsam ufak bir katkı yaparım ama içim daralır, elime mümkün olduğunca az gitsin isterim.", puan: 2 }, { text: "Manevî ve maddî gücüm ölçüsünde, hayır işine severek katkı sağlarım; ne cimrilik ne de aşırı cömertlik yaparım.", puan: 3 }, { text: "Yardım kampanyasını fırsat bilecek şekilde bazen öne çıkar, daha fazlaısını koyayım diye gereksiz riskler alabilirim; ya da her işi üstlenip ‘daha fazla kazanırım’ gibi bir hırs kaplar beni.", puan: 4 }, { text: "‘Yardım kampanyası’ denince aklıma bile gelmez, asıl derdim kendi kazancımı çoğaltmak. Sürekli daha fazlasını isteyip belki de yardıma duyarsız kalırım.", puan: 5 } ] },
            { soru: "Uzun zamandır göz koyduğunuz bir eşyayı (telefon, araba vs.) alacak paranız var. Fakat evde başka ihtiyaçlar da söz konusu.", options: [ { text: "Zaten para harcamaktan çekinirim, o eşyayı da almayıp paramı tutarım. Kendim de mahrum kalırım.", puan: 1 }, { text: "Ucuz bir alternatifi zoraki alırım, yine de kaliteliden kaçınırım, ‘Param gitmesin’ diye fazla kısarım.", puan: 2 }, { text: "İhtiyacım varsa, makul fiyata iyi ürünü seçerim; aile veya diğer masraflarımı da gözardı etmem.", puan: 3 }, { text: "Kalite veya lüks aşkına, paramı fazlaca harcarım, sonrasında boş cüzdanla kalırım.", puan: 4 }, { text: "Gözüm dönmüş halde en pahalıyı, en lüksü alır, belki borçlanıp tamahkâr bir şekilde hareket ederim.", puan: 5 } ] },
            { soru: "Ay sonunda fatura ve zorunlu masraflarınız geliyor, elinizde az para kalmış. Nasıl davranırsınız?", options: [ { text: "Temel ihtiyacı bile keser, hatta kendimi aç-açıkta bırakma pahasına parayı saklarım.", puan: 1 }, { text: "Anca faturalara yettiyse bile rahatsız olurum, param gitmesin diye bazen ödemeleri geciktiririm.", puan: 2 }, { text: "Ne kadar masraf varsa karşılar, sorumlu şekilde öder, kaldıysa birikim veya sonraki ay için plan yaparım.", puan: 3 }, { text: "Yeni bir şey arayışına girip, belki kalan az parayla da riskli harcamalar yaparım, ‘Daha fazla kazanayım’ hırsıyla kendimi tehlikeye atabilirim.", puan: 4 }, { text: "Maaşın büyük kısmı yetmeyebilir, ek para bulup aşırı tüketir, borçlanıp yine de doyumsuz harcamalarımı sürdürürüm.", puan: 5 } ] },
            { soru: "Misafir geleceğini öğrendiniz, bir sofra kuracaksınız. Bütçenizi nasıl ayarlarsınız?", options: [ { text: "En ucuz malzemeler, hatta yetersiz ikram olur. Misafire de önem vermem, ‘Masraf olmasın’ derim.", puan: 1 }, { text: "Biraz ikram yapsam da içim cız eder, yine ‘Nasıl daha ucuza çıkarım?’ diye hesaplarım, belki misafirleri de memnun edemem.", puan: 2 }, { text: "İhtiyaca göre özen gösterir, israfa kaçmadan yeterli sofra kurarım.", puan: 3 }, { text: "Birçok gereksiz çeşit hazırlayıp masrafı yükseltebilirim, ‘Misafire şatafat gösterisi’ diye düşünebilirim.", puan: 4 }, { text: "Limitsiz masraf yapar, görkemli ama gereksiz bolluk içinde para saçarım. Sonra da maddi sıkıntıya girebilirim.", puan: 5 } ] },
            { soru: "Birine borç vermeniz istendi. Kişinin gerçekten ihtiyacı var ve geri ödeyebilecek. Sizinse paranız var.", options: [ { text: "Asla vermem, para bende kalmalı. İnsanlara borç falan vermek bana göre değil.", puan: 1 }, { text: "Küçük bir miktar vermek belki, ama tedirgin olurum. Keşke hiç istemeselerdi.", puan: 2 }, { text: "Güvenilir buluyorsam, imkânım varsa seve seve veririm. Bana ya da ona fayda olur; neticede bu makul bir dayanışma.", puan: 3 }, { text: "Sırf kâr gözeterek ‘faiz alabilir miyim?’ gibi hırslı düşüncelere kapılabilirim; ya da ‘daha fazla kazanırsam’ diye riskli işlere sokabilirim.", puan: 4 }, { text: "Her şey bana gelsin diye, ‘Borç vermeyeyim, kendim kullanayım, bende kalsın’ diyor da olabilirim veya tam tersine parayı umarsızca heba edecek kadar açgözlü/macera düşkünü olabilirim. (Aşırı para hırsı ve yönetimsizlik).", puan: 5 } ] },
            { soru: "Arkadaşlarınız lüks bir restorana gitmek istiyor. Fiyatlar çok yüksek ama davet ediliyorsunuz. Sizin maddî durumunuz nedir?", options: [ { text: "Kesinlikle gitmem, ‘Paraya yazık’ diyerek hiçbir şekilde böyle yerlere adım atmam.", puan: 1 }, { text: "Zoraki gitsem de hiçbir şey söylemem, belki bir çorbayla oturur, malımı korurum.", puan: 2 }, { text: "Bütçeme göre hareket eder, normal bir menü seçerim. Lükse veya gereksiz harcamaya girmem.", puan: 3 }, { text: "Arkadaş ortamında öne çıkmak için pahalı menüler sipariş edebilir, fazlaca para kaptırabilirim.", puan: 4 }, { text: "Gösteriş yapar, en lüks tabakları alır, abartılı masrafı göze alırım; doymak bilmeyen tamah duygusuyla şekil yaparım.", puan: 5 } ] },
            { soru: "Aile içinde bir konuda para gerekiyor (örneğin çocuk eğitimi, sağlık). Sizin elinizde yeterli meblağ var.", options: [ { text: "Asla elimi cebime atmam, gerekirse onlar sıkıntı çeksin, benim param azalmasın.", puan: 1 }, { text: "Çok cüzi bir miktar koyar, ‘Benim de katkım var’ deyip asıl parayı saklarım.", puan: 2 }, { text: "İhtiyaç neyse, makul ölçüde destek olurum; aile sorumluluğumu yerine getiririm.", puan: 3 }, { text: "Bazen ‘Aileye yardım edeyim’ diye büyük para koyarım, sonra da ‘Bana yetmiyor’ diye daha fazla kazanmak için riskli işlere dalarım. Hırs içerimde.", puan: 4 }, { text: "Ben paramı kendime saklar, ailemin ihtiyacına sırt çeviririm; ya da tam tersi, parayı anormal şekilde har vurup harman savururum. Sonuçta yine tamah ve istikrarsızlık.", puan: 5 } ] },
            { soru: "Bir işte fazladan kazanç elde etmek için meşru olmayan yollara sapma fikri aklınıza geliyor (örneğin vergi kaçırma, kumar, yalan beyan).", options: [ { text: "Ben zaten para kazanmaya bile üşenirim; riskli, haram veya helal fark etmez, hiçbir işe girmem.", puan: 1 }, { text: "Azıcık iş yapsam da konfor alanımda kalırım, ek kazanç veya risk aramam, yine de çok pinti biçimde paramı saklarım.", puan: 2 }, { text: "Meşru yollarla rızkımı kazanır, harama yaklaşmam. Zaruri değilse yan işi de düşünmem.", puan: 3 }, { text: "Daha fazlasını kazanmak için yalan veya vergi kaçırma gibi konulara sıcak bakabilirim.", puan: 4 }, { text: "Gözüm para hırsından dönmüş olabilir; haram-helal sınırı yok, yeter ki çok para gelsin. Kumar, yasa dışı iş, fark etmez.", puan: 5 } ] },
            { soru: "Size hediye gelecek dendi, nasıl bir tutum içindesiniz?", options: [ { text: "Hediye veren olsun, almaya bile çekinirim, belki ‘Onu da saklayayım’ derim. Ama kendim kimseye hediye almam, malım azalmasın.", puan: 1 }, { text: "Ufak tefek şeyler dışında hediyelerden bile rahatsız olurum, paramı, eşyamı kimseyle paylaşmam.", puan: 2 }, { text: "Hediyeleşmenin sünnet olduğunu bilirim, hem alır hem de gücüm yettiğince veririm. Orta yoldayım.", puan: 3 }, { text: "Hediye konusunu da fırsata çevirip ‘Bana daha pahalı şey alın’ diye isteklerimi sıralayabilirim.", puan: 4 }, { text: "Hediye alma-verme işini gösterişe dönüştürür, her şeyi kendime daha fazla kazandırma kapısı olarak görürüm. ‘Ne kadar çok toplarsam o kadar iyi’ derim.", puan: 5 } ] },
            { soru: "Bir markette kampanya var. Gerekli-gereksiz birçok ürün ucuz görünüyor. Paranızı nasıl kullanırsınız?", options: [ { text: "En gerekli ürünleri bile almamaya meylederim, ‘Param cepte kalsın’ diye. Kampanya olsa da harcama yapmak istemem.", puan: 1 }, { text: "Çok hesap yapar, en ucuzunu seçer, bazen kalitesiz olduğunu bile bile paramı harcamaktan kaçınırım.", puan: 2 }, { text: "Listeye bakar, gerçekten ihtiyacım olan şeyleri kampanyadan faydalanarak alırım, gereksiz olanı almam.", puan: 3 }, { text: "Kampanyayı görünce hepsini doldurabilirim, sonrasında asıl ihtiyacımdan fazla alıp masrafım artar.", puan: 4 }, { text: "İndirimli-indirimsiz bakmadan daldığım gibi doldurur, tam bir açgözlülük gösterir, paramı sonuna kadar tüketirim.", puan: 5 } ] },
        ]
    },
    sukur: {
        title: "Nimetlerin Hepsi Senin Gözünde Boş mu, Yoksa Sırf Sen mi Mükemmel Oldun?",
        concepts: { tefrit: "Nankörlük", fazilet: "Şükür", ifrat: "Kibre Kapılma" },
        questions: [
            { soru: "Bir burs, prim veya maaş zammı aldınız. Nasıl tepki verirsiniz?", options: [ { text: "Ne yapayım ki, çok az, hiç de yeterli değil. Zaten bana uygun değil, hâlâ perişanım, hiçbir şeye yaramaz.", puan: 1 }, { text: "Kısmen faydası var ama yine de ‘Niye daha çok değil?’ diyerek neredeyse hiç memnun olmam.", puan: 2 }, { text: "‘Elhamdülillah’ diyerek sevinir, bu artışı hakkıyla kullanır, Rabb’ime şükrederim. İnsanî vesilelere de teşekkür ederim.", puan: 3 }, { text: "İçten içe ‘Bu zammı hak ettim, zaten ben olmasam kimse çalışmaz’ diye kibirlenmenin eşiğindeyim.", puan: 4 }, { text: "Tamamen ‘Bakın, ben mükemmelim, bana zam yapmaları da normal’ diyerek böbürlenirim.", puan: 5 } ] },
            { soru: "Elinizdeki imkanlarla ev-araba vb. mütevazı düzeyde. Fakat yine de bir nimettir. Sizin hissiyatınız?", options: [ { text: "Hiç memnun değilim, ‘Kötü araba, kötü ev; aslında yok gibi bir şey’ diye yakınıp dururum.", puan: 1 }, { text: "Kısmen işimi görse de ben sürekli ‘Daha iyisi olmalıydı, bu ne’ diye tatminsizim.", puan: 2 }, { text: "Şükrünü bilirim, elimde olanı değerlendirir, fırsat bulursam iyileştirme de yaparım. Ama asıl tutumum ‘Elhamdülillah, kâfi…’", puan: 3 }, { text: "İyi ki var, ama ‘Ben gayretimle bunu aldım, bana minnet etmesin kimse’ gibi azıcık böbürlenme hissediyorum.", puan: 4 }, { text: "Bende varsa ‘Harikasın ben!’ diye aşırı övünür, çevremdekileri küçük görürüm.", puan: 5 } ] },
            { soru: "Bir toplantıda başarılarınızdan bahsediliyor. Sizce bunun sebebi nedir?", options: [ { text: "Başarı falan yok, ben zaten hep şanssızım. Olan da yetersiz, kimse beni övmesin.", puan: 1 }, { text: "Biraz başarı var ama yine de ‘Ne işe yarar?’ diyerek negatif düşünürüm.", puan: 2 }, { text: "Hamdederim; motivasyon kaynağı oldu. Emeği geçenlere teşekkür edip, ‘Allah’a şükür’ derim.", puan: 3 }, { text: "‘Ben tabii iyiyim, kendi gayretimle başardım, normaldir’ diye kendimi yüceltmeye eğilimliyim.", puan: 4 }, { text: "Resmen gurur abidesi gibi ‘Benden üstün var mı?’ diyerek kibre kapılır, küçük dağları ben yarattım havasına bürünürüm.", puan: 5 } ] },
            { soru: "Sosyal medyada sizinle ilgili övücü bir haber gördünüz: “Ne kadar çalışkan, harika insan!” vb.", options: [ { text: "Ne harikası? Kendime hiç güvenim yok, aslında hiç başarı yok, bu övgü koca bir yalan.", puan: 1 }, { text: "Övüyorlar ama bence hiçbir işe yaramaz, çünkü değersizim.", puan: 2 }, { text: "Teşekkür ederim. ‘Yaptıysam Allah’ın izniyle yaptım’ diyerek haddimi bilir, şükrederim.", puan: 3 }, { text: "İçten içe ‘Haklılar, gerçekten iyi iş çıkardım. Bu övgüyü hak ediyorum’ diye gururlanırım.", puan: 4 }, { text: "‘Elbette ben eşsizim, bu kadar övgü bile az’ diyerek kendimi göklere çıkarırım.", puan: 5 } ] },
            { soru: "Bir yolculukta otobüs konforlu, hava da güzel, rahatsızlık yok. Nimeti nasıl algılarsınız?", options: [ { text: "Bana yine kötü rast geldi; şu koltuk da dikiş tutmuyor, hava da aslında çekilmez. Hep memnuniyetsizim.", puan: 1 }, { text: "Fena değil ama yine de sürekli kusur arayıp tadını çıkarmam.", puan: 2 }, { text: "‘Elhamdülillah, rahat bir yolculuk oluyor. Şikayet edilecek bir şey göremiyorum, nimet kıymetini bilirim.", puan: 3 }, { text: "Evet rahat, ama ‘Zaten ben olmasam bu yolculuk eksik kalırdı, her işte bir payım var’ diye tuhaf bir özgüven hissi.", puan: 4 }, { text: "Kendimi çok özel hissedip ‘Bu konforu hak eden benim, diğer yolcular da kim!’ diye kibirlenebilirim.", puan: 5 } ] },
            { soru: "Evdeki temel ihtiyaçlarınız rahatça karşılanıyor. Bir tencere kaynıyor, çayınız hazır. Sizin ruh hâliniz?", options: [ { text: "Bana ne! Hepsi yetersiz, keyif vermez. Yine de her şey kötü.", puan: 1 }, { text: "Ufak bir rahatlık var ama çok da abartacak bir şey yok, nankörce küçümsüyorum.", puan: 2 }, { text: "Rabbim’e şükreder, nasibime razı olurum; yokluktan iyidir, gayet kıymetli nimet.", puan: 3 }, { text: "Belki ‘Ben çalıştım, ben kazandım’ diyerek aileye ‘Sayemde yiyorsunuz’ gibi gururlu söylemler yaparım.", puan: 4 }, { text: "Büsbütün büyüklük taslar, ‘Bu ev, bu yiyecekler benim başarımla var!’ diyerek insanlara üstten bakarım.", puan: 5 } ] },
            { soru: "Kendinizden daha zor durumda olanları görünce ne düşünürsünüz?", options: [ { text: "Bende zaten hiçbir şey yok ki, onlardan iyi durumda olduğumu bile düşünmem. Sürekli kendime acıyorum.", puan: 1 }, { text: "Zorluklarını görsem de ben de memnun değilim, ben de dertliyim. Kimseye minnet duymuyorum.", puan: 2 }, { text: "Onların hâline bakarak şükreder, elimden gelen yardımı yapmaya çalışırım. Nimetlerimin kıymetini anlarım.", puan: 3 }, { text: "İçimde biraz ‘Ben onlardan üstünüm, oh’ hissi gelebiliyor, ama farkında olmadan gururlanıyorum.", puan: 4 }, { text: "Tam olarak ‘Ben özelim, onlar benim seviyeme erişemez’ şeklinde küstahça kibir içindeyim.", puan: 5 } ] },
            { soru: "Çok büyük bir müjde veya başarı kazandınız (mesela hediye ev, büyük ikramiye). Sevinç anındaki hâliniz?", options: [ { text: "Hiç coşku yok, yine de ‘Ne işe yarayacak, bana faydası olmaz’ diye nankörce tavır.", puan: 1 }, { text: "Kısa süreli memnuniyet, ardından ‘Eh, bu da yetmez ki’ diyerek sönükleştiririm.", puan: 2 }, { text: "Büyük bir şükür, ‘Elhamdülillah!’ deyip sevinirim; nimeti yerinde kullanmaya çalışırım.", puan: 3 }, { text: "Hemen övünür, ‘Kendi çabamla kazandım’ diyerek az biraz gururlu pozlara girerim.", puan: 4 }, { text: "Öylesine kibirlenirim ki, insanlara hava atıp ‘Görüyor musunuz, ben üstünüm’ tavrıyla dolaşırım.", puan: 5 } ] },
            { soru: "İnsanların “Ne kadar şanslısın!” dediği bir nimete sahipsiniz. Onlara ne cevap verirsiniz?", options: [ { text: "‘Ne şansı yahu, hiçbir işime yaramadı’ derim, nankörce sızlanırım.", puan: 1 }, { text: "Biraz kıymetini bilsem de ‘O kadar da önemli değil’ diye memnuniyetsiz konuşurum.", puan: 2 }, { text: "‘Evet, Rabbim nasip etti. Umarım ben de onu hayra kullanabilirim’ şeklinde teşekkür ile karşılarım.", puan: 3 }, { text: "‘Tabii, bu benim hakkım. Ben zaten çok çalışıyorum, ben olmazsam bu nimete kimse layık olmazdı’ diye böbürlenmeye yaklaşırım.", puan: 4 }, { text: "Alenen kibirle ‘Ben seçilmişim, siz değilsiniz!’ modunda gezip insanlara tepeden bakarım.", puan: 5 } ] },
            { soru: "Etrafınızdaki insanlar size jest yapıp bir sürpriz kutlama düzenledi. Nasıl yaklaşıyorsunuz?", options: [ { text: "Anlamsız bulurum, ‘Bana sürpriz yapsanız ne, zaten hayatım kötü’ gibi yakınırım.", puan: 1 }, { text: "Kısmen hoşuma gider ama yine de ‘Keşke daha büyük yapsalardı’ veya ‘Zaten önemsiz’ diye nankörce tavır.", puan: 2 }, { text: "Teşekkür eder, onlara da minnet duyarım; Rabbim’e de hamd ederek anı yaşarım.", puan: 3 }, { text: "Kendimi kutlamanın asıl odağı görüp ‘Ben zaten bunu fazlasıyla hak ediyorum’ diye gururlanırım.", puan: 4 }, { text: "Abartılı bir ego patlamasıyla ‘Bana kutlama az bile, ben muhteşemim!’ diyerek aşırı kibir gösteririm.", puan: 5 } ] },
            { soru: "Bir nimeti kaybetme riskiniz var (iş, ev, sağlık). Diğerleri ‘En azından şu an elinizde var’ diyor. Sizin cevabınız?", options: [ { text: "Ne elindesi, ben zaten hiçbir şeyi hakkıyla yaşayamıyorum, hep kayıptayım.", puan: 1 }, { text: "Azıcık var ama ben tatmin olmuyorum, nankörce ‘Bana yine faydası yok’ diyorum.", puan: 2 }, { text: "‘Elhamdülillah, en azından şu an sahip olduğuma şükrederim. Kaybetmemek için de meşru tedbir alırım.’", puan: 3 }, { text: "Böyle risk anlatanlara ‘Boş verin, bende var. Kaybetmem. Ben üstünüm’ gibi kibirli yaklaşabilirim.", puan: 4 }, { text: "Tamamen ‘Ben böyle risklere boyun eğmem, nimetin kaybı olamaz, çünkü ben mükemmelim’ diyerek ukalaca konuşurum.", puan: 5 } ] },
        ]
    },
    tevekkul: {
        title: "Plan Yok, Saldım Çayıra mı, Yoksa Her Şey Aklında Mı Hapsoldu?",
        concepts: { tefrit: "Tedbirsizlik", fazilet: "Tevekkül", ifrat: "Aşırı Endişe" },
        questions: [
            { soru: "İş arayışındasınız. Nasıl davranırsınız?", options: [ { text: "Hiç CV hazırlamam, ilanlara bakmam. ‘Rabbim rızık verir’ deyip boşta dururum.", puan: 1 }, { text: "Arada bakarım ama gayrette zayıfım, ‘Allah büyüktür’ diyerek çok başvuru yapmam.", puan: 2 }, { text: "Düzenli araştırır, başvurularımı yapar, dua ve tevekkülle sonucu Allah’a bırakırım.", puan: 3 }, { text: "Sürekli ‘Ya bulamazsam!’ diye panik, geceleri uyuyamama, her yere saldırma, abartılı endişe yaşarım.", puan: 4 }, { text: "Tamamen ‘Her şey bende bitiyor, dünya vasıtaları olmadan asla kurtulamam!’ gibi aşırı kaygı.", puan: 5 } ] },
            { soru: "Bir sınava gireceksiniz. Nasıl hazırlanırsınız?", options: [ { text: "Çalışmam, ‘Olursa olur, olmazsa Rabbim istemedi’ derim. Tedbir yok.", puan: 1 }, { text: "Az bir çalışma, ‘Oluruna bırakayım’ tavrı. Detaylı hazırlık yapmaktan kaçarım.", puan: 2 }, { text: "Sistemli şekilde öğrenir, emek veririm; dua ve tevekkülle sonuca razı olurum.", puan: 3 }, { text: "Günlerce uykusuz, panik atak halinde, aşırı stresle abartılı hazırlık; yine de huzurum yok.", puan: 4 }, { text: "‘Ya başaramazsam? Hayatım mahvolur!’ diyerek manevî boyut hiç yok, sadece dünya kaygısı.", puan: 5 } ] },
            { soru: "Bir seyahat planlarken, risk faktörlerini ne kadar hesaba katarsınız?", options: [ { text: "Hiç plan, rezervasyon veya hazırlık yapmam, ‘Allah büyük’ diye öylece yola çıkarım.", puan: 1 }, { text: "Basit bir bakarım ama çok ilgilenmem, ‘Olduğu kadar’ derim.", puan: 2 }, { text: "Bilet, konaklama, güvenlik gibi tedbirleri alır, dua ve tevekkülle yolculuğa çıkarım.", puan: 3 }, { text: "En ufak detayı bile hesaplar, aşırı endişeyle ‘Ya uçak düşerse, ya otel yanarsa’ gibi senaryolarla boğuşurum.", puan: 4 }, { text: "Tamamen dünyevî planlara hapsolur, manevî rahatlığı aklıma bile getirmem, ‘Her şeyi kontrol etmeliyim!’ kaygısıyla yaşarım.", puan: 5 } ] },
            { soru: "Sağlık konusunda tavrınız? Diyelim periyodik muayene gerekli.", options: [ { text: "Hiç doktora gitmem, ‘Nasıl olsa kaderimde ne varsa o olur’ deyip tedbiri sıfırlarım.", puan: 1 }, { text: "Hafif semptomlarda bile ‘Boşver geçer’ diyerek ciddi muayeneden kaçınırım.", puan: 2 }, { text: "Belirtiler varsa doktora görünür, tedavimi uygular, ardından Allah’a tevekkül ederim.", puan: 3 }, { text: "En ufak ağrıda bile ‘Eyvah büyük hastalık var mı’ diyerek aşırı endişe, sürekli doktora koşma, derin panik.", puan: 4 }, { text: "Her hastalığı bana musallat olacak sanarak manevî huzuru kaybedip tam bir dünya takıntısı yaşarım.", puan: 5 } ] },
            { soru: "Bir başkası diyor ki: “Plan yapmadan olmaz, gayret göstermelisin!” Siz ne düşünüyorsunuz?", options: [ { text: "‘Plan da nedir, Allah diledi mi olur’ diye her şeyi boş bırakırım.", puan: 1 }, { text: "Kısmen haklı ama yine de fazla uğraşmaya mecalim yok, ‘bırakalım’ derim.", puan: 2 }, { text: "Plan yapmak, sebeplere sarılmak güzeldir, sonra Allah’a güvenmek esas. İkisini birlikte yaparım.", puan: 3 }, { text: "Plan manyağı olup, her ayrıntıya saplanır, en ufak aksiliğe tahammül edemem, ‘Ya bozulursa!’ diye paniğe kapılırım.", puan: 4 }, { text: "Sebeplere neredeyse tapınacak kadar güvenip maneviyata hiç yer bırakmam, her şeyi dünyaya bağlarım.", puan: 5 } ] },
            { soru: "Bir arkadaşınız “Malzemeleri ayarla, ben de dua edeyim, inşallah güzel olur” dedi. Nasıl yorumlarsınız?", options: [ { text: "Dua etmenin de malzeme ayarlamanın da bir önemi yok, nasipse olur, değilse olmaz.", puan: 1 }, { text: "Dua iyi de, ben çok uğraşmayayım, nasip diyelim, belki yapılır.", puan: 2 }, { text: "Evet, hem fiilî tedbir (malzemeleri hazırlama) hem de dua (Allah’a güven) birlikte olmalı. Dengeli buluyorum.", puan: 3 }, { text: "Ben sadece malzemelere, planlara inanırım; duanın pek manası yok diye içten içe düşünebilirim.", puan: 4 }, { text: "Her şeyi dünyevî bakışla yaparım, ‘Dua fuzuli zaman kaybı’ veya ‘Mutlaka ben kurtaracağım’ gibi manevî inkâr hissi.", puan: 5 } ] },
            { soru: "Uzun vadeli bir proje aksadı, finansal kaynak gecikti. Çevreniz sabır ve tevekkül öneriyor. Siz?", options: [ { text: "‘Olursa olur, olmazsa olmaz’ diye tamamen salar, projenin gerektirdiği tedbirleri almayı bırakırım.", puan: 1 }, { text: "Az uğraşmıştım, şimdi daha da vazgeçerim, nasipse olur, gerisine bakmam.", puan: 2 }, { text: "Aksaklıkta yeni çözüm yolları arar, Rabb’e dua edip süreci yönetmeye çalışırım.", puan: 3 }, { text: "Stres ve panik içinde, her gün ‘Ne olacak, ne yapacağız’ diye huzursuz olurum.", puan: 4 }, { text: "Maddi kaygılarım öyle yüksek ki manevî inancım ve tevekkülüm neredeyse sıfır, her an korku yaşıyorum.", puan: 5 } ] },
            { soru: "Sınav sonuç günü, siz “Artık elimden geleni yaptım” mı diyorsunuz yoksa?", options: [ { text: "Ben hiç çalışmadım ki, ‘Hayırlısı neyse o olur’ diye tamamen bıraktım.", puan: 1 }, { text: "Kısmen çalıştım ama pek ciddiye almadım; şimdi de ‘Allah ne yazdıysa o’ derim. Sonuca dair hazırlığım yok.", puan: 2 }, { text: "Çalıştım, dua ettim, sonucu sabırla bekliyorum. Olumsuz olursa da kendime yeni yol çizerim.", puan: 3 }, { text: "Anksiyete tavan, ‘Ya düşük gelirse hayatım biter!’ diyerek aşırı dünyacı kaygıya boğulurum.", puan: 4 }, { text: "Sınav sonucunu neredeyse ilahlık düzeyinde görüp, ‘Her şey bende biter, manevî boyuta inanmam’ diyerek aşırı endişe ve dünyevî yaklaşım içindeyim.", puan: 5 } ] },
            { soru: "Yeni bir iş yeri açmak istiyorsunuz. “Nasip” kavramını nasıl anlıyorsunuz?", options: [ { text: "Nasipse olur, diye hiçbir hazırlık yapmam, mekân seçmem, müşteri analizi filan yok.", puan: 1 }, { text: "Biraz heveslenir, yarım yamalak planla gerisini boş bırakırım.", puan: 2 }, { text: "Araştırır, sermayeyi planlar, dua ve tevekkülle açarım. Başarı da başarısızlık da Allah’ın takdirine bağlı, ama ben üzerime düşeni yaparım.", puan: 3 }, { text: "Mekân, müşteri, stok gibi her şeyi katı şekilde kontrol edip ‘Ya başarısız olursa’ korkusuyla panik içinde davranırım.", puan: 4 }, { text: "Manevî bakış yok; sadece ‘Ben, ben!’ diyerek stresi tavan yapar, maddî önlemlerle kendimi yıpratırım.", puan: 5 } ] },
            { soru: "Sağlam bir sigorta, yedek planlar, bir sürü garanti almadan rahat edemeyen birisi misiniz?", options: [ { text: "Sigorta, garanti falan umursamam, ‘Alın yazısı neyse o’ der fiilî tedbir almayı unuturum.", puan: 1 }, { text: "Kısıtlı önlem, çok da üstünde durmam.", puan: 2 }, { text: "Temel sigorta, mantıklı yedek plan gibi tedbirler normal. Sonra tevekkülle süreci sürdürürüm.", puan: 3 }, { text: "Sigorta ve garantilere rağmen yine de ‘Ya bir şey ters giderse!’ diye geceleri uyuyamam, sürekli panik.", puan: 4 }, { text: "Sanki tüm güvenliği ben sağlamak zorundayım; Allah faktörü yokmuş gibi her zerreyi kontrol etme takıntısı.", puan: 5 } ] },
            { soru: "Bir hastalık haberi duydunuz. Yakınınız “Rabbim şifa verir, doktor da yardımcı olur inşallah” diyor. Siz nasıl yaklaşıyorsunuz?", options: [ { text: "Doktor veya tedbir düşünmem, ‘Ölürsem ölürüm’ gibi tamamen bırakırım.", puan: 1 }, { text: "Biraz bakarım ama ciddiyet yok, ‘Nasıl olsa mukadderat’ deyip tedaviyi de önemsemem.", puan: 2 }, { text: "Hekime gider, ilaç vs. uygular, Allah’tan şifa dileyerek manevi açıdan da sabır ve duayla yaklaşırım.", puan: 3 }, { text: "Her gün ‘Ya kötüleşirsem, ya tedavi işe yaramazsa’ diye kaygı krizlerine girer, strese boğulurum.", puan: 4 }, { text: "Hayatı tamamen dünya boyutunda görüyorum; maneviyata inançsız, her an ‘Benim kontrolüm dışında bir şey olamaz’ diye titriyorum.", puan: 5 } ] },
        ]
    },
    haya: {
        title: "Dillenirken Susuyor musun, Yoksa Perdesiz Bir Sergi mi Sunuyorsun?",
        concepts: { tefrit: "Aşırı Utangaçlık", fazilet: "Haya", ifrat: "Hayâsızlık" },
        questions: [
            { soru: "Topluluk önünde konuşma yapmanız isteniyor. Normal bir sunum veya hak savunma olabilir.", options: [ { text: "Çok utanırım, kesinlikle konuşamam; ‘Ben kimim ki…’ diye geri çekilirim, sanki dilim tutulur.", puan: 1 }, { text: "Minik bir konuşma yaparım ama çok çekinir, gerektiğini bile tam söyleyemem.", puan: 2 }, { text: "Duruma uygun giyinip ölçülü, saygılı bir sunum yaparım. Utanma var ama beni engellemez.", puan: 3 }, { text: "Bazen argo veya abartılı sözlerle patavatsızlaşabilir, ‘Ne utanması, ben her şeyi söylerim’ derim.", puan: 4 }, { text: "Hiç utanma gözetmem, müstehcen veya çirkin ifadeler bile kullanabilirim, umursamam.", puan: 5 } ] },
            { soru: "Bir haksızlık gördünüz, orada itiraz etmek veya şahitlik yapmak gerekiyor. Siz?", options: [ { text: "Ne kadar haksız olursa olsun, ben ‘kimseyi incitemem’ diye çekinir, hakkı söylemeye bile utanırım.", puan: 1 }, { text: "Kısmen konuşmaya niyetlenir ama ortamda utanıp geriye çekilirim.", puan: 2 }, { text: "Yanlışın karşısında nezaketle itiraz etmek gerekir, uygun üslupla konuşurum. Aşırıya da gitmem.", puan: 3 }, { text: "Bağırıp çağırmayı, sertleşmeyi normal bulurum. ‘Ne utanması, ben gerçeği pat diye söyleyebilirim’ derim.", puan: 4 }, { text: "Ağır hakaret, küfür veya ifşa yoluna giderek hayâ duvarlarını tamamen yıkarım, çirkinleşirim.", puan: 5 } ] },
            { soru: "Mahrem konuların konuşulduğu bir ortamdasınız. Nasıl davranırsınız?", options: [ { text: "En ufak şeyde yüzüm kızarır, konuyu duymak bile istemem, meşru bilgi olsa dahi aşırı utangaç kalırım.", puan: 1 }, { text: "Biraz bilgi alsam da çekinir, genelde kabuğuma çekilirim.", puan: 2 }, { text: "Ahlâkî ve dinî sınırlar içindeyse makul konuşabilir, ciddiyeti koruyarak gerekliyse açıklama yaparım.", puan: 3 }, { text: "Mizah vs. adıyla bazen edep sınırını zorluyorum; ‘açık-saçık espri’ yapabilirim.", puan: 4 }, { text: "Çıplak ifadeler, fuhuşvari anlatımlar, müstehcen konuşmalardan çekinmem, hayâ perdesi yok.", puan: 5 } ] },
            { soru: "Davet edildiğiniz bir toplu yemekte, sofradaki cinsiyet karması ortama nasıl uyum sağlarsınız?", options: [ { text: "O kadar utanırım ki başım önümde, kimseyle göz göze gelmeden, belki yemekten bile çekinir, kalkarım.", puan: 1 }, { text: "Otururum ama konuşmam, ‘Aman yanlış anlaşılırım’ endişesiyle sessiz kalırım.", puan: 2 }, { text: "Edep ölçülerinde sohbet edip, yemeğe katılırım; gereğinde konuşur, gereğinde susarım.", puan: 3 }, { text: "Şakayı veya sözü abartıp bazen saygısız ifadelere bile kayabilirim, ‘Ne var canım’ diye utanmam.", puan: 4 }, { text: "Aşırı samimi veya uygunsuz davranışlar (fiziksel temas, müstehcen espri) yapmaktan çekinmem.", puan: 5 } ] },
            { soru: "Arkadaşlar müzikli bir eğlence düzenliyor; herkes eğleniyor, siz ne yaparsınız?", options: [ { text: "Ortamda bulunamam, utanırım; dans, müzik, en masum hâliyle olsa bile bana gerilim yaratıyor.", puan: 1 }, { text: "Arada otururum ama kıpırdayamam, aşırı çekinirim, belki de tadına varamadan köşede kalırım.", puan: 2 }, { text: "Ölçülü şekilde eğlenirim; edep ve ahlâk sınırlarını aşmayan neyse ona katılır, çirkin işlerden sakınırım.", puan: 3 }, { text: "Çoğu zaman dans veya müziği abartır, hayâsız denmeyecek kadar ama yine de sınırları zorlayacak tavırlar sergilerim.", puan: 4 }, { text: "Edep dışı hareketler, müstehcen danslar, çirkin davranışlar sergilemekten çekinmem.", puan: 5 } ] },
            { soru: "Bir toplulukta, size ‘Kendini tanıt’ deniyor. Nasıl hissediyorsunuz?", options: [ { text: "Aşırı utanıyorum, ismimi bile söyleyemeyecek kadar sıkılıyorum, sesim çıkmıyor.", puan: 1 }, { text: "Kısmen tanıtsam da devamını getiremiyor, yüzüm kızararak ‘Tamam bu kadar’ der susarım.", puan: 2 }, { text: "Öz ve net şekilde kim olduğumu anlatır, gerekli yerde dururum, utanma duygumu yönetebilirim.", puan: 3 }, { text: "Belki bazı patavatsız veya gereksiz açık sözler sarfederim, ‘Ne utanacağım canım’ diye spontane söylerim.", puan: 4 }, { text: "Aklıma gelen her şeyi sınırsızca anlatır, özel detayları bile ifşa ederim; hayâ gözetmem.", puan: 5 } ] },
            { soru: "Size bir haksızlık yapıldı, ama siz “Utanırım, ses çıkaramam” diyerek mi davranırsınız?", options: [ { text: "Evet, meşru hakkımı bile talep edemem, ölesiye çekinirim.", puan: 1 }, { text: "Biraz mırıldanırım ama hemen susarım; utangaçlık yine engel olur.", puan: 2 }, { text: "Gereken tepkiyi edep dairesinde veririm; hayâ demek haksızlık karşısında tamamen susmak değil.", puan: 3 }, { text: "Anında çok sert çıkışarak hayâ sınırlarını dahi aşabilirim, bazen kaba söz kullanırım.", puan: 4 }, { text: "Kesinlikle çirkin, müstehcen veya hakaret dolu ifadelerle saldırırım, hayâ yok.", puan: 5 } ] },
            { soru: "Bir edep dışı film/klip açıldı, herkes bakıyor. Siz?", options: [ { text: "O kadar utanırım ki gözlerimi kaparım, oradan uzaklaşırım, belki de hiçbir şekilde ‘Kapatın’ diyemem.", puan: 1 }, { text: "Hoşnutsuzum ama aşırı çekingenliğim yüzünden duruma müdahale de edemem, sessizce kalırım.", puan: 2 }, { text: "Uygunsuz ise ‘Arkadaşlar bu rahatsız edici’ diyerek nazikçe kapatılmasını veya ben çıkmayı tercih ederim; hayâ duygumu korurum.", puan: 3 }, { text: "İzleyebilirim, hatta gülüşüp yorum yapabilirim. ‘Ne var canım, doğal şeyler’ gibi utanmaz bir havaya kayabilirim.", puan: 4 }, { text: "Hayâsız görüntülere açıkça dalar, belki teşvik de ederim, hiç utanma hissetmem.", puan: 5 } ] },
            { soru: "Zorunlu bir sağlık muayenesi var, doktorla özel konuları konuşmanız lazım. Nasıl hissediyorsunuz?", options: [ { text: "O kadar utanırım ki doktora bile derdimi tam anlatamam, tedavim aksar.", puan: 1 }, { text: "Kısmen söylerim ama çekinerek, belki önemli detayları bile saklarım.", puan: 2 }, { text: "Edep içinde ama gerektiği kadar bilgi veririm, sağlığım için sorumluluğumu bilirim.", puan: 3 }, { text: "Belki gereğinden fazla detayı rahatça anlatır, doktora ‘Ne var canım’ diyerek patavatsızlaşabilirim.", puan: 4 }, { text: "Hayâsızca aşırı özel şeyleri gereksiz biçimde gösterir, doktoru bile tuhaf duruma sokarım.", puan: 5 } ] },
            { soru: "Arkadaş grubunda müstehcen şakalar dönüyor. Sizin duruşunuz?", options: [ { text: "Rahatsız olsam da çekingenlikten hiçbir şey diyemem, orada kalırım ama sessizim.", puan: 1 }, { text: "Biraz utanır, konuyu değiştirmeye çekinirim, yine pasif kalırım.", puan: 2 }, { text: "Uygunsuz buluyorsam kibarca ‘Arkadaşlar, bu konuyu aşmayalım’ diyerek tepkimi belirtir, kalkarım gerekiyorsa.", puan: 3 }, { text: "Bazen onlara ayak uydurup müstehcen espri eklerim, biraz hayâ perdesini zorluyorum.", puan: 4 }, { text: "En müstehcen, fuhuşvari şakaları yaparak ortamda ‘Hayâsız’ tutum sergilerim.", puan: 5 } ] },
            { soru: "Toplum içinde romantik veya fiziksel yakınlık gösterileri (sarılma, öpüşme) size ne kadar normal geliyor?", options: [ { text: "Ben en masum temasta bile ürkerim, aşırı utanırım, belki sevdiğime bile yakınlaşamam.", puan: 1 }, { text: "Kısmen kabul ederim ama yine de çok çekingenim, toplum içinde herhangi bir dokunuştan kaçınırım.", puan: 2 }, { text: "İslam ve toplumsal normlar çerçevesinde zararsız bir sevgi gösterisi yapabilirim, ölçüyü aşmam.", puan: 3 }, { text: "Alenen sarılma, öpüşme veya ileri yakınlık göstermekten çok da sakınmam. ‘Ne utanacağım canım’ derim.", puan: 4 }, { text: "Çok müstehcen, toplumun rahatsız olacağı davranışları bile umursamaz şekilde sergilerim.", puan: 5 } ] },
        ]
    },
};


const ICONS = {
  kibir:`<svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"/></svg>`,
  cesaret:`<svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.286zm0 13.036h3.75"/></svg>`,
  comertlik:`<svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>`,
  zan:`<svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639l4.433-4.433a.93.93 0 011.316 0l4.433 4.433c.39.39.39 1.026 0 1.416l-4.433 4.433a.93.93 0 01-1.316 0l-4.433-4.433z"/></svg>`,
  hirs:`<svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-3.976 5.197m-4.26-4.26l-6.174 6.175"/></svg>`,
  vesvese:`<svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/></svg>`,
  adalet:`<svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0012 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 01-2.153.24c-1.355 0-2.693-.44-3.797-1.242L7.334 4.97"/></svg>`,
  hikmet:`<svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5zm0 0v5.592A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-5.998V14"/></svg>`,
  iffet:`<svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8 11V7a4 4 0 118 0v4M5 9h14l1 12H4L5 9z"/></svg>`,
  ihlas:`<svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/></svg>`,
  hased:`<svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5V6.75a4.5 4.5 0 119 0v3.75M3.75 21.75h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H3.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/></svg>`,
  sabir:`<svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  hilm:`<svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.182 15.182a4.5 4.5 0 01-6.364 0M21 12a9 9 0 11-18 0 9 9 0 0118 0zM9 9.75h.008v.008H9V9.75zm6 0h.008v.008H15V9.75z"/></svg>`,
  kanaat:`<svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 11.25v8.25a2.25 2.25 0 01-2.25 2.25H5.25a2.25 2.25 0 01-2.25-2.25v-8.25M12 15v-7.5M12 7.5h-4.5m4.5 0h4.5M3 11.25h18"/></svg>`,
  sukur:`<svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.042 21.672L13.684 16.6m0 0l-2.51 2.225.569-9.47 5.227 7.917-3.286-.672zm-7.518-.267A8.25 8.25 0 1120.25 10.5"/></svg>`,
  tevekkul:`<svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z"/></svg>`,
  haya:`<svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6A2.25 2.25 0 005.25 5.25v3.75m10.5 0a2.25 2.25 0 012.25 2.25v3.75a2.25 2.25 0 01-2.25 2.25h-1.5a2.25 2.25 0 01-2.25-2.25V12a2.25 2.25 0 012.25-2.25m-6 0a2.25 2.25 0 00-2.25 2.25v3.75a2.25 2.25 0 002.25 2.25h1.5A2.25 2.25 0 009 12V9a2.25 2.25 0 00-2.25-2.25M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
};

let S = {
  screen:'welcome', testKey:null, answers:{}, qi:0,
  scores:null, gemini:null, loadingGemini:false,
  history:JSON.parse(localStorage.getItem('ahlakHistory')||'{}'),
  expandedHistory:null
};

function saveHistory(){ localStorage.setItem('ahlakHistory', JSON.stringify(S.history)); }

function pct(s){
  const t=s.tefrit+s.fazilet+s.ifrat;
  if(!t) return {tefrit:0,fazilet:0,ifrat:0};
  const a=Math.round((s.tefrit/t)*100), b=Math.round((s.fazilet/t)*100);
  return {tefrit:a, fazilet:b, ifrat:Math.max(0,100-a-b)};
}

function render(){
  const app=document.getElementById('app');
  app.className='container mx-auto max-w-3xl p-4 sm:p-6 py-10 fade-in';
  const screens={welcome:screenWelcome,start:screenStart,quiz:screenQuiz,result:screenResult,history:screenHistory};
  app.innerHTML=(screens[S.screen]||screenWelcome)();
  window.scrollTo(0,0);
}

function screenWelcome(){return `
  <div class="flex flex-col items-center justify-center min-h-[85vh] text-center">
    <h1 class="text-5xl md:text-7xl font-bold text-emerald-400 mb-4">Kalbinin Haritası</h1>
    <h2 class="text-3xl md:text-5xl font-semibold text-gray-200 mb-6">Ahlak Pusulası</h2>
    <p class="text-lg text-gray-400 max-w-2xl mb-10">İçindeki uçurumlar ve doruklar... 17 farklı testte kalbine ayna tut!</p>
    <button class="btn py-4 px-10 text-xl" data-action="goStart">Hemen Başla</button>
  </div>`;}

function screenStart(){
  const cards=Object.entries(TESTS).map(([key,test])=>`
    <div class="card clickable" data-action="startTest" data-key="${key}">
      <div class="flex justify-center mb-4">${ICONS[key]||''}</div>
      <h2 class="text-2xl font-bold text-emerald-400 text-center mb-2">${test.concepts.fazilet}</h2>
      <p class="text-gray-400 text-sm text-center mb-6 min-h-[40px]">${test.title}</p>
      <div class="flex justify-between items-center font-semibold">
        <span class="text-yellow-500 text-sm">${test.concepts.tefrit}</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        <span class="text-red-400 text-sm">${test.concepts.ifrat}</span>
      </div>
    </div>`).join('');
  return `
    <div class="text-center mb-8">
      <h1 class="text-5xl font-bold text-emerald-400 mb-3">Ahlak Pusulası</h1>
      <p class="text-xl text-gray-400 mb-6">17 farklı testte kalbine ayna tut!</p>
      <button class="btn btn-indigo" data-action="goHistory">Ahlak Haritamı Görüntüle</button>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">${cards}</div>`;}

function screenQuiz(){
  const test=TESTS[S.testKey], q=test.questions[S.qi];
  const progress=((S.qi+1)/test.questions.length)*100;
  const opts=q.options.map(opt=>`
    <div class="option-label${S.answers[S.qi]===opt.puan?' selected':''}" data-action="answer" data-score="${opt.puan}">${opt.text}</div>`).join('');
  return `
    <div>
      <div class="progress-wrap"><div class="progress-fill" style="width:${progress}%"></div></div>
      <div class="text-center mb-8">
        <h1 class="text-4xl font-bold text-emerald-400 mb-2">${test.concepts.fazilet}</h1>
        <p class="text-lg text-gray-400">${test.title}</p>
        <p class="text-gray-500 mt-2">Soru ${S.qi+1} / ${test.questions.length}</p>
      </div>
      <div class="card mb-6">
        <p class="text-xl mb-6 leading-relaxed">${q.soru}</p>
        <div>${opts}</div>
      </div>
      <div class="flex justify-between gap-4">
        <button class="btn btn-gray" data-action="prev"${S.qi===0?' disabled':''}>Geri</button>
        ${S.qi<test.questions.length-1?`<button class="btn" data-action="next"${S.answers[S.qi]===undefined?' disabled':''}>İleri</button>`:''}
      </div>
      <div class="text-center mt-6">
        <button class="text-gray-400 hover:text-emerald-400 transition-colors" data-action="goStart">Test Seçimine Geri Dön</button>
      </div>
    </div>`;}

function screenResult(){
  const test=TESTS[S.testKey], p=pct(S.scores);
  const gem=S.loadingGemini
    ?`<div class="flex flex-col items-center p-8"><div class="spinner"></div><p class="mt-4 text-gray-300">Kalbinizin sesi dinleniyor...</p></div>`
    :S.gemini
    ?S.gemini.streaming
      ?`<div class="text-gray-300 leading-relaxed whitespace-pre-wrap" id="gemini-stream"><span class="stream-cursor inline-block w-0.5 h-4 bg-emerald-400 animate-pulse"></span></div>`
      :`<div class="text-gray-300 leading-relaxed" id="gemini-stream">${renderGeminiText(S.gemini.text||'')}</div>`
    :'';
  const next=!S.gemini?.streaming&&S.gemini?.sonraki_test?.key&&TESTS[S.gemini.sonraki_test.key]
    ?`<div class="card mt-8"><h3 class="text-xl font-bold text-emerald-300 mb-3 text-center">Sıradaki Adım</h3>
       <p class="text-center text-gray-400 mb-4">${S.gemini.sonraki_test.gerekce}</p>
       <div class="flex justify-center"><button class="btn btn-indigo" data-action="startTest" data-key="${S.gemini.sonraki_test.key}">Başla: ${TESTS[S.gemini.sonraki_test.key].concepts.fazilet} Testi</button></div>
     </div>`:'';
  return `
    <div>
      <div class="card" id="result-card">
        <div class="text-center pb-6">
          <p class="font-semibold text-emerald-500 mb-4">Ahlak Pusulası Sonuç Kartı</p>
          <h1 class="text-4xl font-bold text-emerald-400 mb-2">${test.concepts.fazilet}</h1>
          <p class="text-lg text-gray-400 mb-8">${test.title}</p>
          <div class="flex justify-around text-center my-4">
            <div><p class="text-yellow-400 font-bold">${test.concepts.tefrit}</p><p class="text-6xl font-bold text-gray-100 tracking-tighter mt-1" id="pt">0%</p></div>
            <div><p class="text-emerald-400 font-bold">${test.concepts.fazilet}</p><p class="text-6xl font-bold text-gray-100 tracking-tighter mt-1" id="pf">0%</p></div>
            <div><p class="text-red-400 font-bold">${test.concepts.ifrat}</p><p class="text-6xl font-bold text-gray-100 tracking-tighter mt-1" id="pi">0%</p></div>
          </div>
        </div>
        <hr class="border-gray-700 mb-6"/>
        <h2 class="text-2xl font-bold text-emerald-400 text-center mb-4">Size Özel Değerlendirmeniz</h2>
        <div class="bg-gray-900/50 rounded-lg p-4 min-h-[120px]">${gem}</div>
      </div>
      ${next}
      <div class="flex flex-col sm:flex-row justify-center gap-4 mt-8">
        <button class="btn btn-blue" data-action="share"${!S.gemini?' disabled':''}>Sonucu Paylaş</button>
        <button class="btn btn-gray" data-action="goStart">Yeni Test Seç</button>
      </div>
    </div>`;}

function screenHistory(){
  const keys=Object.keys(S.history);
  const content=!keys.length
    ?`<div class="card text-center p-10"><p class="text-gray-400 text-lg">Henüz hiç test tamamlamadın!</p></div>`
    :keys.map(key=>{
      const test=TESTS[key]; if(!test) return '';
      const p=pct(S.history[key].percentages), isExp=S.expandedHistory===key, gd=S.history[key].geminiData;
      return `<div>
        <div class="card clickable" data-action="toggleHistory" data-key="${key}"${isExp?' style="border-radius:0.75rem 0.75rem 0 0"':''}>
          <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
            <div class="flex items-center gap-4">${ICONS[key]||''}<div><h2 class="text-2xl font-bold text-emerald-400">${test.concepts.fazilet}</h2><p class="text-gray-400 text-sm">${test.title}</p></div></div>
            <div class="flex gap-4 font-semibold text-center">
              <div class="w-20"><p class="text-yellow-500 text-xs">${test.concepts.tefrit}</p><p class="text-2xl">${p.tefrit}%</p></div>
              <div class="w-20"><p class="text-emerald-500 text-xs">${test.concepts.fazilet}</p><p class="text-2xl">${p.fazilet}%</p></div>
              <div class="w-20"><p class="text-red-400 text-xs">${test.concepts.ifrat}</p><p class="text-2xl">${p.ifrat}%</p></div>
            </div>
          </div>
        </div>
        ${isExp&&gd?`<div class="p-6 bg-gray-900/70 border border-t-0 border-gray-700 rounded-b-xl fade-in">
          <div class="text-gray-300 leading-relaxed">${renderGeminiText(gd.text||gd.sonuclarinAynasi||'')}</div>
        </div>`:''}
      </div>`;}).join('');
  return `
    <div>
      <div class="mb-10">
        <h1 class="text-5xl font-bold text-emerald-400 mb-3">Ahlak Haritam</h1>
        <p class="text-xl text-gray-400">Tamamladığın testler ve manevi yolculuğunun izleri.</p>
      </div>
      <div class="space-y-4">${content}</div>
      <div class="text-center mt-10"><button class="btn" data-action="goStart">Test Seçimine Geri Dön</button></div>
    </div>`;}

function renderGeminiText(text){
  return text
    .replace(/\*\*(.+?)\*\*/g,'<strong class="text-emerald-300 text-lg block mt-5 mb-1">$1</strong>')
    .replace(/\n/g,'<br>');
}

async function fetchGemini(scores){
  S.loadingGemini=false; S.gemini={streaming:true,text:'',sonraki_test:{key:'',gerekce:''}}; render();
  const test=TESTS[S.testKey], p=pct(scores);
  const otherKeys=Object.keys(TESTS).filter(k=>k!==S.testKey).join(', ');
  const system=`Sen derin bir irfan ve hikmet ehlisin. Yazıların Osmanlı nesrinin letafetini taşır; her cümle mütefekkir, ağırbaşlı ve ruhani bir derinlikle yoğrulmuştur. Şu kelimeleri ve benzerlerini MUTLAKA kullan: kalb, nefis, ruh, cehd, itidal, ihsan, muhabbet, irade, fıtrat, inkisar, azm, tevekkül, rıza, gaflet, saadet, hüzün, müteşekkir, mütevazı, ledün, irfan, feyz, bâtın, zâhir, himmet, halvet, istikamet, mertebe, makam, kemal, zillet, izzet, nükte, letafet, hamiyet, hakikat, keşf, tecelli. Cümleler lirik, derin ve akıcı olsun. Klişe ve yüzeysel ifadelerden kaçın.`;
  const prompt=`Kullanıcı "${test.title}" testini tamamladı.\nKavramlar: Tefrit (eksik uç)=${test.concepts.tefrit}, Fazilet (denge)=${test.concepts.fazilet}, İfrat (aşırı uç)=${test.concepts.ifrat}.\nSonuçlar: %${p.tefrit} ${test.concepts.tefrit}, %${p.fazilet} ${test.concepts.fazilet}, %${p.ifrat} ${test.concepts.ifrat}.\n\nŞu başlıkları sırayla kullanarak yaz (başlıkları **başlık** formatında yaz):\n**Selamlama** (2-3 cümle samimi karşılama)\n**Sonuçların Bir Aynası** (en az 6 cümle derin tahlil, sayısal sonuçları yorumla)\n**Tefekkür Köşesi** (en az 5 cümle hikmet geleneği)\n**İlahi Rehberlik** (en az 5 cümle manevi yönlendirme)\n**Pratik Adımlar** (en az 5 cümle somut öneriler)\n\nEn son satıra yalnızca şunu yaz: SONRAKI_TEST:key|gerekce (key şu listeden biri olmalı: ${otherKeys})`;
  try{
    const res=await fetch('/api/gemini',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({system,prompt})});
    const reader=res.body.getReader(), decoder=new TextDecoder();
    let fullText='', buf='';
    while(true){
      const{done,value}=await reader.read(); if(done) break;
      buf+=decoder.decode(value,{stream:true});
      const lines=buf.split('\n'); buf=lines.pop();
      for(const line of lines){
        if(!line.startsWith('data: ')||line==='data: [DONE]') continue;
        try{
          const token=JSON.parse(line.slice(6)).choices?.[0]?.delta?.content||'';
          if(token){ fullText+=token; S.gemini.text=fullText; const el=document.getElementById('gemini-stream'); if(el){ const cur=el.querySelector('.stream-cursor'); if(cur) cur.remove(); el.insertAdjacentText('beforeend',token); el.insertAdjacentHTML('beforeend','<span class="stream-cursor inline-block w-0.5 h-4 bg-emerald-400 animate-pulse"></span>'); } }
        }catch{}
      }
    }
    const lines=fullText.split('\n'), last=lines[lines.length-1].trim();
    if(last.startsWith('SONRAKI_TEST:')){
      const[k,g]=last.slice(13).split('|');
      S.gemini.sonraki_test={key:(k||'').trim(),gerekce:(g||'').trim()};
      fullText=lines.slice(0,-1).join('\n').trim();
    }
    S.gemini={streaming:false,text:fullText,sonraki_test:S.gemini.sonraki_test};
    S.history[S.testKey]={percentages:scores,geminiData:S.gemini}; saveHistory();
    render(); animNums();
  }catch(e){
    S.gemini={streaming:false,text:'Bir hata oluştu. Lütfen tekrar deneyin.',sonraki_test:{key:'',gerekce:''}};
    render();
  }
}

function animNums(){
  if(S.screen!=='result'||!S.scores) return;
  const p=pct(S.scores);
  [['pt',p.tefrit],['pf',p.fazilet],['pi',p.ifrat]].forEach(([id,target])=>{
    const el=document.getElementById(id); if(!el) return;
    const t0=performance.now(), dur=1200;
    function step(now){
      const pr=Math.min((now-t0)/dur,1), ease=pr*(2-pr);
      el.textContent=Math.round(ease*target)+'%';
      if(pr<1) requestAnimationFrame(step);
    } requestAnimationFrame(step);
  });
}

function attachEvents(){
  document.getElementById('app').addEventListener('click',e=>{
    const el=e.target.closest('[data-action]'); if(!el||el.disabled) return;
    const {action,key,score}=el.dataset;
    if(action==='goStart'){S.screen='start';render();}
    else if(action==='goHistory'){S.screen='history';render();}
    else if(action==='startTest'){S.testKey=key;S.answers={};S.qi=0;S.scores=null;S.gemini=null;S.loadingGemini=false;S.screen='quiz';render();}
    else if(action==='answer'){
      S.answers[S.qi]=parseInt(score); render();
      const test=TESTS[S.testKey];
      if(S.qi<test.questions.length-1) setTimeout(()=>{S.qi++;render();},350);
      else setTimeout(()=>calcAndShow(),350);
    }
    else if(action==='next'&&S.answers[S.qi]!==undefined){S.qi++;render();}
    else if(action==='prev'&&S.qi>0){S.qi--;render();}
    else if(action==='share') shareImg();
    else if(action==='toggleHistory'){S.expandedHistory=S.expandedHistory===key?null:key;render();}
  });
  if(S.screen==='result') setTimeout(animNums,100);
}

function calcAndShow(){
  let scores={tefrit:0,fazilet:0,ifrat:0};
  Object.values(S.answers).forEach(s=>{
    if(s===1)scores.tefrit+=2; else if(s===2)scores.tefrit+=1;
    else if(s===3)scores.fazilet+=2; else if(s===4)scores.ifrat+=1; else scores.ifrat+=2;
  });
  S.scores=scores; S.screen='result'; render(); animNums(); fetchGemini(scores);
}

async function shareImg(){
  const card=document.getElementById('result-card'); if(!card) return;
  try{
    const canvas=await html2canvas(card,{scale:2.5,backgroundColor:'#1f2937',useCORS:true});
    const a=document.createElement('a');
    a.href=canvas.toDataURL('image/png',1.0);
    a.download=`${TESTS[S.testKey]?.concepts.fazilet||'sonuc'}-karti.png`;
    a.click();
  }catch(e){alert('Resim oluşturulamadı.');}
}

render();
attachEvents();
</script>
</body>
</html>